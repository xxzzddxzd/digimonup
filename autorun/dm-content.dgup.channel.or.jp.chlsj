1536000; includeSubDomains"},{"name":"X-Content-Type-Options","value":"nosniff"},{"name":"X-DNS-Prefetch-Control","value":"off"},{"name":"X-Download-Options","value":"noopen"},{"name":"X-Frame-Options","value":"SAMEORIGIN"},{"name":"X-Permitted-Cross-Domain-Policies","value":"none"},{"name":"X-XSS-Protection","value":"0"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Access-Control-Allow-Credentials","value":"true"},{"name":"ETag","value":"W/\"164-WKZRcZjFxQFH4c9UaDwOQz92PgI\""}]},"body":{"text":"{\"_data\":\"\"}","charset":"utf-8"}}},{"status":"COMPLETE","method":"POST","protocolVersion":"HTTP/1.1","scheme":"https","host":"dm-content.dgup.channel.or.jp","actualPort":443,"path":"/api/notice/list","query":null,"tunnel":false,"keptAlive":true,"webSocket":false,"remoteAddress":"dm-content.dgup.channel.or.jp/99.83.175.186","clientAddress":"198.18.72.253/198.18.72.253","times":{"start":"2026-07-16T20:48:17.323+08:00","requestBegin":"2026-07-16T20:48:17.335+08:00","requestComplete":"2026-07-16T20:48:17.792+08:00","responseBegin":"2026-07-16T20:48:17.879+08:00","end":"2026-07-16T20:48:18.198+08:00"},"durations":{},"totalSize":"126197","ssl":{"protocol":"TLSv1.2","cipherSuite":"TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256"},"request":{"sizes":{"body":"97","headers":516},"mimeType":"application/json","charset":null,"contentEncoding":null,"header":{"firstLine":"POST /api/notice/list HTTP/1.1","headers":[{"name":"Host","value":"dm-content.dgup.channel.or.jp"},{"name":"X-Unity-Version","value":"6000.3.11f1"},{"name":"Accept","value":"*/*"},{"name":"Authorization","value":"Bearer 26666bef-520a-402c-b95d-b4eea531ce51"},{"name":"Accept-Language","value":"zh-CN,zh-Hans;q=0.9"},{"name":"Accept-Encoding","value":"gzip, deflate, br"},{"name":"Content-Type","value":"application/json"},{"name":"Content-Length","value":"97"},{"name":"x-idempotency-key","value":"c5e8c251-feac-41c2-8c33-9b21c117c4c3"},{"name":"Connection","value":"keep-alive"},{"name":"User-Agent","value":"1.0.2; IPhonePlayer; Unity/6000.3.11f1; DeviceModel/iPhone14,3; OS/iOS 16.1.1"},{"name":"Cookie","value":"_clck=1kt954y%5E2%5Eg7s%5E0%5E2388"}]},"body":{"text":"{\"_version\":\"1.0.2\",\"_dataNo\":\"ded91528d845767b07f5a6ce30f85e6bddc314e65dce0f91d8627d9aa9f83e08\"}","charset":null}},"response":{"sizes":{"body":"124931","headers":653},"mimeType":"application/json","charset":"utf-8","contentEncoding":null,"header":{"firstLine":"HTTP/1.1 200 OK","headers":[{"name":"Date","value":"Thu, 16 Jul 2026 12:48:17 GMT"},{"name":"Content-Type","value":"application/json; charset=utf-8"},{"name":"Content-Length","value":"124931"},{"name":"Connection","value":"keep-alive"},{"name":"Cross-Origin-Opener-Policy","value":"same-origin"},{"name":"Cross-Origin-Resource-Policy","value":"same-origin"},{"name":"Origin-Agent-Cluster","value":"?1"},{"name":"Referrer-Policy","value":"no-referrer"},{"name":"Strict-Transport-Security","value":"max-age=31536000; includeSubDomains"},{"name":"X-Content-Type-Options","value":"nosniff"},{"name":"X-DNS-Prefetch-Control","value":"off"},{"name":"X-Download-Options","value":"noopen"},{"name":"X-Frame-Options","value":"SAMEORIGIN"},{"name":"X-Permitted-Cross-Domain-Policies","value":"none"},{"name":"X-XSS-Protection","value":"0"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Access-Control-Allow-Credentials","value":"true"},{"name":"ETag","value":"W/\"1e803-oXxjzFqCOKinPlIUHlyTh10ktzg\""}]},"body":{"text":"{\"_code\":0,\"_maintenanceInfos\":{\"_list\":[{\"_type\":1,\"_version\":0,\"_isForced\":false,\"_startAt\":1784124000000,\"_endAt\":1785423600000},{\"_type\":4,\"_version\":9,\"_isForced\":false,\"_startAt\":1784021177000,\"_endAt\":1784098800000}],\"_isWhitelisted\":false},\"_noticeList\":{\"_list\":[{\"_noticeId\":\"bbb10510-86bd-46fb-aac0-50b2cf178a45\",\"_type\":3,\"_contents\":{\"_list\":[{\"_languageType\":5,\"_title\":\"[Annonce] Problèmes actuellement identifiés\",\"_message\":\"Nous vous remercions de jouer à Digimon UP.\\n\\nNous avons actuellement identifié les problèmes suivants.\\nNous vous présentons nos sincères excuses pour la gêne occasionnée et vous remercions de votre patience pendant que nous travaillons à leur résolution.\\n\\n▼Problèmes connus\\n① En appuyant sur le bouton Défi depuis le « Mur Apocalymon », l'entrée dans le donjon peut prendre un certain temps.\\n* En attendant quelques instants après avoir appuyé sur le bouton, il est possible de poursuivre normalement.\\n\\n② Le tutoriel du Champ de viande peut se bloquer dans certaines conditions.\\nLors du passage du niveau 39 au niveau 40, si l'écran d'Exploration est déjà affiché et que vous accédez immédiatement au Champ de viande dès son déverrouillage pour poursuivre le contenu, la progression peut être bloquée.\\n\\n③ Les résultats du mode PvP peuvent être incorrects avec certains paramètres de langue.\\n\\n④ Une fenêtre d'erreur s'affiche lors de l'ouverture de la fenêtre des options de confidentialité.\\n\\n⑤ Lorsqu'un nouveau message est publié dans le chat, la position de défilement est automatiquement déplacée tout en bas.\\n\\nNous vous présentons nos excuses pour la gêne occasionnée.\\nNous espérons que vous continuerez de soutenir DIGIMON UP.\"},{\"_languageType\":4,\"_title\":\"【공지】현재 발생하고 있는 오류에 관하여\",\"_message\":\"항상 \u2018디지몬 UP\u2019을 이용해 주셔서 진심으로 감사드립니다.\\n\\n현재 다음과 같은 오류가 확인되었습니다.\\n이용하시는 고객 여러분께 불편을 드려 죄송합니다만,\\n오류가 수정될 때까지 잠시만 기다려 주시기를 부탁드립니다.\\n\\n▼발생 중인 오류\\n① \u2018아포카리몬의 벽\u2019에서 도전 버튼을 탭했을 때, 던전 입장까지 시간이 오래 걸리는 현상\\n\u203B버튼을 탭한 후 일정 시간 기다리시면 진행이 가능합니다.\\n불편을 드려 죄송합니다.\\n\\n② 특정 조건에서 \u2018고기밭\u2019 튜토리얼 진행이 중단된다.\\n스테이지 39에서 스테이지 40으로 이동할 때, 탐험 화면을 미리 표시한 상태에서,\\n\u2018고기밭\u2019이 해금된 직후 \u2018고기밭\u2019으로 이동하여 콘텐츠를 진행하면 진행이 중단된다.\\n\\n③ 특정 언어 설정에서 PvP에 입장했을 때 정상적인 결과가 나오지 않는다.\\n\\n④ 개인정보 옵션 팝업이 표시될 때 오류 팝업이 나타난다.\\n\\n⑤ 채팅이 업데이트되었을 때 스크롤 위치가 강제로 맨 아래로 이동해 버린다.\\n\\n고객 여러분께 불편을 드려 대단히 죄송합니다.\\n앞으로도 \u2018디지몬 UP\u2019을 잘 부탁드립니다.\"},{\"_languageType\":1,\"_title\":\"【お知らせ】現在発生している不具合について\",\"_message\":\"いつも「デジモンUP」をご利用いただき、誠にありがとうございます。\\n\\n現在、以下の不具合を確認しております。\\nご利用のお客さまにはご迷惑をおかけしておりますが、\\n不具合の修正まで、いましばらくお待ちくださいますようお願いいたします。\\n\\n▼発生中の不具合\\n①「アポカリモンウォール」で戦闘ボタンをタップした際に、ダンジョンへの入場に時間がかかってしまう\\n　\u203Bボタンをタップした後一定時間お待ちいただくと進行は可能な状況です。\\n　　お手間をおかけしてしまい申し訳ございません。\\n\\n②特定の条件下で肉畑のチュートリアルが進行不能となる\\n　ステージ39からステージ40へ移行する際に、探検画面を事前に表示した状態で、\\n　肉畑が解放された直後に肉畑へ移動してコンテンツを進行すると、進行不能となってしまう\\n\\n③特定の言語設定でPvPに入場した際に、正常な結果にならない\\n\\n④プライバシーオプションのポップアップを表示した際に、エラーポップアップが表示される\\n\\n⑤チャットが更新された際に、スクロール位置が強制的に最下部へ移動してしまう\\n\\nお客様にはご迷惑をおかけし、大変申し訳ございません。\\n今後とも「デジモンUP」をよろしくお願いいたします。\"},{\"_languageType\":6,\"_title\":\"[Hinweis] Bezüglich aktuell auftretender Probleme\",\"_message\":\"Vielen Dank, dass du \u201EDIGIMON UP\u201C spielst.\\n\\nDerzeit sind die folgenden Probleme bekannt.\\nWir entschuldigen uns für die Unannehmlichkeiten und bitten um Geduld, während wir an der Behebung dieser Probleme arbeiten.\\n\\n▼Aktuelle Probleme\\n① Beim Tippen auf den Kampf-Button bei \u201EApocalymon-Mauer\u201C dauert es sehr lange, bis man den Dungeon betreten kann.\\n* Wenn du nach dem Tippen auf den Button eine gewisse Zeit wartest, solltest du fortfahren können.\\nWir entschuldigen uns für die Unannehmlichkeiten.\\n\\n② Im Fleischfeld-Tutorial kann unter bestimmten Bedingungen nicht fortgefahren werden.\\nWenn beim Übergang von Stage 39 zu Satge 40 der Erkundungsbildschirm vorher angezeigt wird und du das Fleischfeld direkt nach dessen Freischaltung betrittst und mit den Inhalt fortfährst, friert das Spiel ein und es ist kein Fortfahren möglich.\\n\\n③ Beim Betreten des PvP mit bestimmten Spracheinstellungen werden die Ergebnisse nicht korrekt angezeigt.\\n\\n④ Beim Anzeigen des Pop-ups für die Datenschutzeinstellungen erscheint eine Fehlermeldung.\\n\\n⑤ Beim Aktualisieren des Chats springt die Scrollposition automatisch ans Ende der Seite.\\n\\nWir entschuldigen uns für die entstandenen Unannehmlichkeiten.\\nWir danken dir für deine weitere Unterstützung von \u201EDIGIMON UP\u201C.\"},{\"_languageType\":7,\"_title\":\"[Aviso] Sobre los problemas detectados actualmente\",\"_message\":\"Gracias por jugar a DIGIMON UP.\\n\\nActualmente, hemos detectado los siguientes problemas.\\nLamentamos las molestias ocasionadas y te pedimos que esperes un poco más mientras trabajamos para solucionarlos.\\n\\n▼ Problemas detectados:\\n① Al tocar el botón de combate en el Muro de Apocalymon, el acceso a la mazmorra tarda más de lo habitual.\\n　* Puedes continuar si esperas un momento después de tocar el botón.\\n　Lamentamos las molestias ocasionadas.\\n\\n② El tutorial del Campo de Digicarne puede quedar bloqueado bajo ciertas condiciones.\\n　El problema se produce al pasar de la etapa 39 a la etapa 40 si abres previamente la pantalla de exploración y accedes al Campo de Digicarne inmediatamente después de desbloquearlo y avanzas en el contenido.\\n\\n③ Al acceder al PvP con determinados ajustes de idioma, los resultados no se muestran correctamente.\\n\\n④ Al abrir la ventana emergente de las opciones de privacidad, aparece una ventana emergente de error.\\n\\n⑤ Cuando el chat se actualiza, la posición de desplazamiento se mueve automáticamente hasta la parte inferior.\\n\\nOfrecemos una sincera disculpa por las molestias ocasionadas.\\nEsperamos que sigas disfrutando de DIGIMON UP.\"},{\"_languageType\":2,\"_title\":\"【通知】关于当前出现的异常问题\",\"_message\":\"感谢您一直以来对《数码宝贝 UP》的支持与喜爱。\\n\\n目前已确认存在以下异常问题。\\n给各位玩家造成的不便，我们深表歉意。\\n还请耐心等待问题修复完成。\\n\\n▼当前发生的异常问题\\n①点击\u201C启示录兽之墙\u201D中的战斗按钮后，进入迷宫所需的时间较长\\n　\u203B点击按钮后等待一段时间，仍可正常进行游戏。\\n　　由此给您造成的不便，我们深表歉意。\\n\\n②在特定条件下，\u201C肉田\u201D的新手教程会无法继续进行。\\n　从关卡39进入关卡40时，若事先打开过探索界面，\\n　并在肉田解锁后立即前往肉田推进相关内容，可能会导致游戏无法继续进行。\\n\\n③使用特定语言设置进入PvP时，无法正常显示结果\\n\\n④打开隐私选项弹窗时，会同时显示错误弹窗\\n\\n⑤聊天内容更新时，画面的滚动位置会被强制移至最下方\\n\\n给各位玩家造成不便，我们深表歉意。\\n今后还请继续支持《数码宝贝 UP》。\"},{\"_languageType\":3,\"_title\":\"【公告】關於目前所發生的異常\",\"_message\":\"感謝各位玩家一直以來對《數碼寶貝 UP》的支持與愛護。\\n\\n目前我們已確認到以下異常。\\n非常抱歉造成各位玩家不便，\\n至異常的修正完成為止，還請耐心等候。\\n\\n▼發生中的異常\\n①在「啟示錄獸之牆」中點擊戰鬥按鈕時，進入迷宮需要較長時間\\n　\u203B點擊按鈕後等待一段時間，即可進行。\\n　　造成各位玩家不便，我們深感抱歉。\\n\\n②在特定條件下，肉田的新手教學將無法進行\\n　從關卡39前往關卡40時，若事先開啟探險畫面，\\n　並在肉田解鎖後立即前往肉田進行該內容的話，將無法進行。\\n\\n③透過特定的語言設定進入PvP時，將無法顯示正確結果\\n\\n④顯示私隱選項的彈出視窗時，將出現錯誤的彈出視窗\\n\\n⑤更新聊天時，捲動位置將強制被移動至最底部\\n\\n造成各位玩家不便，我們深感抱歉。\\n今後也請繼續支持《數碼寶貝 UP》。\"},{\"_languageType\":8,\"_title\":\"[Aviso] Sobre os falhas que estão acontecendo atualmente\",\"_message\":\"Agradecemos por sempre jogarem \\\"Digimon UP\\\".\\n\\nIdentificamos as falhas descritas abaixo.\\nPedimos desculpas pelo transtorno causado e agradecemos a paciência até que a as falhas sejam corrigidas.\\n\\n▼Falhas existentes:\\n1- Ao tocar no botão para desafiar a \\\"Parede Apocalymon\\\", leva um tempo até entrar na masmorra.\\n *É possível continuar o progresso ao aguardar alguns instantes.\\n Pedimos perdão por este intervalo.\\n\\n2- Sob certas condições, torna-se impossível dar continuidade ao tutorial do Campo de Carne.\\n　Ao progredir da Fase 39 para a Fase 40 com a tela de Exploração já aberta, torna-se impossível o progresso subsequente após desbloquear e avançar para o Campo de Carne. \\n\\n3- Ao tentar entrar no PvP em certos idiomas, ocorrem-se falhas inesperadas.\\n\\n4- Ao exibir a janela das opções de privacidade, uma nova janela de erro surge.\\n\\n5- Ao atualizar o bate-papo, a tela é rolada automaticamente para a parte inferior.\\n\\nPedimos desculpas pelo transtorno causado.\\nContamos com seu apoio ao \\\"Digimon UP\\\".\"},{\"_languageType\":0,\"_title\":\"[Notice] Regarding Current Issues\",\"_message\":\"Thank you for playing DIGIMON UP!\\n\\nWe have currently identified the following issues. We apologize for any inconvenience caused and ask for your patience while we work on a fix.\\n\\n▼Current Issues\\n① Tapping the attempt button on \\\"Apocalymon Wall\\\" causes a delay when entering the dungeon.\\n* You can proceed if you wait for a little while after tapping the button. Thank you for your patience with this issue.\\n\\n② It becomes impossible to progress in the Meat Field tutorial under certain conditions.\\nIf you view the Explore screen before transitioning from Stage 39 to Stage 40, and then move to the Meat Field and attempt to proceed immediately after, the content softlocks and you will be unable to progress.\\n\\n③ Entering PvP with certain language settings results in things to not operate normally.\\n\\n④ An error pop-up appears when the privacy options pop-up is displayed.\\n\\n⑤ Whenever the chat updates, it scrolls to the bottom.\\n\\nOnce again, we apologize for any inconvenience caused.\\nWe hope you continue to enjoy DIGIMON UP!\"}]}},{\"_noticeId\":\"c68348e7-66ee-4e5d-a34c-4981324e07b2\",\"_type\":3,\"_contents\":{\"_list\":[{\"_languageType\":6,\"_title\":\"Mitteilung zu dringenden Wartungsarbeiten für PvP\",\"_message\":\"Wir haben ein Problem im Zusammenhang mit PvP festgestellt.\\nWir werden Notfallwartungsarbeiten durchführen, um die Ursache dieses Problems zu untersuchen.\\nDie PvP-Funktionen stehen während der Wartungsarbeiten nicht zur Verfügung.\\n\\n▼ Zeitplan für die Wartungsarbeiten\\n15.07.2026 um 23:00 Uhr (UTC +9) \u2013 noch nicht festgelegt\\n\\nWir werden zu einem späteren Zeitpunkt Informationen zur voraussichtlichen Endzeit bekannt geben.\\nWir entschuldigen uns aufrichtig für etwaige Unannehmlichkeiten, die dadurch entstehen könnten.\"},{\"_languageType\":8,\"_title\":\"Aviso de manutenção de emergência para o PvP\",\"_message\":\"Confirmamos um problema relacionado ao PvP.\\nRealizaremos uma manutenção de emergência para investigar a causa desse problema.\\nOs recursos de PvP ficarão indisponíveis durante a manutenção.\\n\\n▼ Cronograma da manutenção\\n15/07/2026 23:00 (UTC +9) \u2013 a definir\\n\\nForneceremos uma atualização sobre a hora prevista para o término da manutenção posteriormente.\\nPedimos sinceras desculpas por qualquer transtorno que isso possa causar.\"},{\"_languageType\":2,\"_title\":\"关于PvP紧急维护的通知\",\"_message\":\"目前已确认存在与PvP相关的故障。\\n为调查该问题原因，我们将进行紧急维护。\\n维护期间将无法使用PvP功能。\\n\\n▼维护时间\\n2026/07/15 23:00 (UTC +9) ～时间未定\\n\\n关于维护结束时间，我们将另行通知。\\n给各位玩家带来不便，我们深表歉意。\"},{\"_languageType\":3,\"_title\":\"關於 PvP 緊急維護的通知\",\"_message\":\"目前已確認存在與 PvP 相關的異常狀況。\\n為調查此問題原因，我們將進行緊急維護。\\n維護期間將無法使用 PvP 功能。\\n\\n▼維護時間\\n2026/07/15 23:00 (UTC +9) ～未定\\n\\n關於維護結束時間，我們將另行通知。\\n造成各位玩家不便，我們深感抱歉。\"},{\"_languageType\":0,\"_title\":\"Notice of Emergency Maintenance for PvP\",\"_message\":\"We have confirmed an issue related to PvP.\\nWe will be performing emergency maintenance to investigate the cause of this issue.\\nPvP features will be unavailable during maintenance.\\n\\n▼ Maintenance Schedule\\n07/15/2026 23:00 (UTC +9) \u2013 TBD\\n\\nWe will provide an update on the estimated end time at a later date.\\nWe sincerely apologize for any inconvenience this may cause.\"},{\"_languageType\":4,\"_title\":\"PVP 긴급 점검에 대한 공지사항\",\"_message\":\"현재 PvP 관련 오류가 확인되었습니다.\\n이에 대한 원인 조사를 위해 긴급 점검을 실시합니다.\\n점검 기간 중에는 PvP 기능을 이용하실 수 없습니다.\\n\\n▼점검 일정\\n2026/07/15 23:00 ~ 미정\\n\\n점검 종료 시각에 대해서는 추후 다시 안내해 드리겠습니다.\\n고객 여러분께 불편을 드려 대단히 죄송합니다.\"},{\"_languageType\":1,\"_title\":\"PvP緊急メンテナンスのお知らせ\",\"_message\":\"現在、PvP関連の不具合が確認できております。\\n本件、原因調査のための緊急メンテナンスを実施いたします。\\nメンテナンス中はPvP機能をご利用いただけません。\\n\\n▼メンテナンス日時\\n2026/07/15 23:00~未定\\n\\n終了時刻につきましては、改めてご案内いたします。\\nお客様にはご迷惑をお掛けし、大変申し訳ございません。\"},{\"_languageType\":5,\"_title\":\"Avis de maintenance d'urgence pour le mode PvP\",\"_message\":\"Nous avons constaté un problème lié au mode PvP.\\nNous allons procéder à une maintenance d'urgence afin d'en déterminer la cause.\\nLes fonctionnalités PvP seront indisponibles pendant la maintenance.\\n\\n▼ Calendrier de la maintenance\\n15/07/2026 à 23 h 00 (UTC +9) \u2013 à déterminer\\n\\nNous vous communiquerons ultérieurement une estimation de l'heure de fin de la maintenance.\\nNous vous prions de bien vouloir nous excuser pour la gêne occasionnée.\"},{\"_languageType\":7,\"_title\":\"Aviso de mantenimiento de emergencia para el modo PvP\",\"_message\":\"Hemos detectado un problema relacionado con el PvP.\\nVamos a realizar un mantenimiento de emergencia para investigar la causa de este problema.\\nLas funciones de PvP no estarán disponibles durante el mantenimiento.\\n\\n▼ Horario del mantenimiento\\n15/07/2026 23:00 (UTC +9) \u2013 Por determinar\\n\\nMás adelante facilitaremos información actualizada sobre la hora estimada de finalización.\\nPedimos sinceras disculpas por las molestias que esto pueda ocasionar.\"}]}},{\"_noticeId\":\"c71dccd9-4f27-44b3-a621-100a2268668d\",\"_type\":2,\"_contents\":{\"_list\":[{\"_languageType\":1,\"_title\":\"【お知らせ】「デジモンUP」正式サービス開始！\",\"_message\":\"07/15 16:00より、正式サービスを開始いたしました。\\n\\n正式サービス開始を記念して、キャンペーンを開催いたします。\\n各キャンペーンの詳細については、それぞれのお知らせおよびゲーム内、公式SNS等をご確認ください。\\n\\n■ 正式サービス記念キャンペーン\\nサービス開始を記念してミニゲームイベントを開催いたします。\\nミニゲームに参加すると、「アグモンパジャマ(足)」と「テイルモンパジャマ(足)」を獲得できます。\\n[開催期間：2026/07/15 16:00 ~ 2026/09/30 23:59]\\n\\n■ 事前キャンペーン報酬\\n以下をプレゼントしております。ホーム画面の「プレゼント」よりお受け取りください。\\n・[バディ]八神太一&アグモン\\n・パタモンパジャマ(頭)、パタモンパジャマ(胴)、パタモンパジャマ(足)\\n・[サポーターデジモン]ゲッコーモン\\n・[サポーターデジモン]ヌメモン\\n・デジエメラルド 3,000個\\n・スキルカードガシャチケット 450枚\\n・サポーターガシャチケット 450枚\\n・ホログラムチケット 1,000枚\\n・いいデジ肉の種 10個\\n・とてもいいデジ肉の種 3個\\n・bit 1,000個\\n[期間：2026/07/15 16:00 ~ 2026/09/30 23:59]\\n\\n\u203B 注意事項\\n・各種キャンペーンの開催期間および内容は、予告なく変更する場合があります。\\n・一部特典は、関連コンテンツの解放後にご使用いただけます。\\n\\n今後とも「デジモンUP」をよろしくお願いいたします。\"},{\"_languageType\":5,\"_title\":\"[Annonce] Lancement officiel de DIGIMON UP !\",\"_message\":\"Nous vous remercions de jouer à notre jeu.\\nNous sommes l'équipe de gestion de DIGIMON UP.\\n\\nCe service a officiellement été lancé le 15/07 à 16 h 00 (UTC +9).\\n\\nNous allons organiser une campagne à l'occasion de ce lancement. Pour plus de détails sur nos campagnes, veuillez consulter les annonces correspondantes dans le jeu et sur nos réseaux sociaux officiels.\\n\\n■ Campagne de lancement officiel du jeu\\nNous organisons un mini-jeu à l'occasion du lancement du jeu.\\nParticipez à la campagne pour obtenir un « Pyjama Agumon (jambes) » et un « Pyjama Gatomon (jambes) ».\\n[Période de l'événement : du 15/07/2026 à 16 h 00 (UTC +9) au 30/09/2026 à 23 h 59 (UTC +9)]\\n\\n■ Campagne de préinscriptions\\nNous offrons les cadeaux suivants à nos joueurs pour le million de préinscriptions dépassé. Vous pouvez les récupérer dans le menu « Cadeau » à l'écran principal.\\n- [Camarade] Taichi Yagami et Agumon\\n- Pyjama Patamon (tête), Pyjama Patamon (corps) et pyjama Patamon (jambes)\\n- [Digimon de soutien] Gekkomon\\n- [Digimon de soutien] Numemon\\n- 3 000 Digiémeraudes\\n- 450 tickets d'invocation de carte de capacité\\n- 450 tickets d'invocation de soutien\\n- 1 000 tickets hologramme\\n- 10 Bonne Digicarnigraines\\n- 3 excellentes Digicarnigraines\\n- 1 000 bits\\n[Période : du 15/07/2026 à 16 h 00 (UTC +9) au 30/09/2026 à 23 h 59 (UTC +9)]\\n\\n* Remarques\\n- Les dates et contenus des campagnes peuvent être modifiés sans préavis.\\n- Certaines récompenses pourront être utilisées après le déblocage du contenu correspondant.\\n\\nNous espérons que vous continuerez de soutenir DIGIMON UP.\"},{\"_languageType\":0,\"_title\":\"[Notice] DIGIMON UP Official Launch!\",\"_message\":\"As of 07/15 16:00 (UTC +9), DIGIMON UP has officially launched!\\n \\nWe are holding the following campaigns to celebrate the official launch. For details on each campaign, please refer to upcoming notices, in-game announcements, and our official social media accounts.\\n\\n■ Official Launch Celebration Campaign\\nTo celebrate the launch, we're holding a Minigame event!\\nTake part in the Minigames to earn Agumon Pajamas (Feet) and Gatomon Pajamas (Feet).\\n[Event Period]: 07/15/2026 16:00 (UTC +9) - 09/30/2026 23:59 (UTC +9)\\n \\n■ Pre-Registration Campaign\\nwe'll be distributing the following gifts! Please claim them via \\\"Presents\\\" on the home screen.\\n\u2022 [Buddy] Tai Kamiya & Agumon\\n\u2022 Patamon Pajamas (Head), Patamon Pajamas (Body) & Patamon Pajamas (Feet)\\n\u2022 [Support Digimon] Gekkomon\\n\u2022 [Support Digimon] Numemon\\n\u2022 DigiEmerald x3,000\\n\u2022 Skill Card Summon Ticket x450\\n\u2022 Support Summon Ticket x450\\n\u2022 Hologram Ticket x1,000\\n\u2022 Good Digimeat Seed x10\\n\u2022 Great DigiMeat Seed x3\\n\u2022 Bit x1,000\\n[Event Period]: 07/15/2026 16:00 (UTC +9) - 09/30/2026 23:59 (UTC +9)\\n\\nNote:\\n* Event periods and campaign details are subject to change without notice.\\n* Some benefits may only be used after unlocking certain content.\\n\\nWe hope you continue to enjoy DIGIMON UP!\"},{\"_languageType\":2,\"_title\":\"【通知】《数码宝贝 UP》正式开服！\",\"_message\":\"感谢您一直以来的支持与喜爱。\\n这里是《数码宝贝 UP》运营团队。\\n\\n自07/15 16:00(UTC+9)起，已正式开服。\\n\\n为纪念正式开服，将举办特别活动。关于各项特别活动的详情，请查看相关通知、游戏内及官方SNS等。\\n\\n■ 正式开服纪念特别活动\\n为纪念开服，将举办小游戏活动。\\n参加小游戏可获得\u201C亚古兽睡衣（脚）\u201D与\u201C迪路兽睡衣（脚）\u201D。\\n〔举办期间：2026/07/15 16:00(UTC+9) ~ 2026/09/30 23:59(UTC+9)〕\\n\\n■ 事前登录特别活动\\n为庆祝事前登录突破100万人，现已发放以下礼物。请至主画面的\u201C礼物\u201D处领取。\\n·〔搭档〕八神太一＆亚古兽\\n·巴达兽睡衣（头）、巴达兽睡衣（身）、巴达兽睡衣（脚）\\n·〔支援型数码宝贝〕守宫兽\\n·〔支援型数码宝贝〕鼻涕兽\\n·数码绿宝石 3,000个\\n·技能卡片扭蛋券 450张\\n·支援型扭蛋券 450张\\n·全息投影券 1,000张\\n·优良数码肉种子 10个\\n·特优数码肉种子 3个\\n·bit 1,000个\\n〔举办期间：2026/07/15 16:00(UTC+9) ~ 2026/09/30 23:59(UTC+9)〕\\n\\n\u203B 注意事项\\n·各项特别活动的举办期间与内容，有可能未经预告径行变更。\\n·部分福利需在解锁相关内容后方可使用。\\n\\n今后还请继续支持《数码宝贝 UP》。\"},{\"_languageType\":3,\"_title\":\"【通知】《數碼寶貝 UP》正式開服！\",\"_message\":\"感謝您一直以來的支持與喜愛。\\n這裡是《數碼寶貝 UP》營運團隊。\\n\\n自07/15 16:00(UTC+9)起，已正式開服。\\n\\n為紀念正式開服，將舉辦特別活動。關於各項特別活動的詳情，請至各通知、遊戲內或官方SNS等處確認。\\n\\n■ 正式開服紀念特別活動\\n為紀念開服，將舉辦小遊戲活動。\\n參加小遊戲可獲得「亞古獸睡衣（腳）」與「迪路獸睡衣（腳）」。\\n〔舉辦期間：2026/07/15 16:00(UTC+9) ~ 2026/09/30 23:59(UTC+9)〕\\n\\n■ 事前登錄特別活動\\n為慶祝事前登錄突破100萬人，已發送以下禮物。請至主畫面的「禮物」處領取。\\n\u2027〔搭檔〕八神太一＆亞古獸\\n\u2027巴達獸睡衣（頭）、巴達獸睡衣（身）、巴達獸睡衣（腳）\\n\u2027〔支援型數碼寶貝〕月光壁虎獸\\n\u2027〔支援型數碼寶貝〕鼻涕獸\\n\u2027數碼綠寶石 3,000個\\n\u2027技能卡片轉蛋券 450張\\n\u2027支援型轉蛋券 450張\\n\u2027全像投影券 1,000張\\n\u2027優良數碼肉種子 10個\\n\u2027特優數碼肉種子 3個\\n\u2027bit 1,000個\\n〔舉辦期間：2026/07/15 16:00(UTC+9) ~ 2026/09/30 23:59(UTC+9)〕\\n\\n\u203B 注意事項\\n\u2027各項特別活動的舉辦期間與內容，有可能未經預告逕行變更。\\n\u2027部分福利需在解鎖相關內容後方可使用。\\n\\n今後還請繼續支持《數碼寶貝 UP》。\"},{\"_languageType\":8,\"_title\":\"[Anúncio] DIGIMON UP foi lançado!\",\"_message\":\"Obrigado por jogar nosso aplicativo.\\nAqui é a Equipe de Administração do DIGIMON UP.\\n\\nÀs 16:00 de 15/07 (UTC+9), lançamos oficialmente o aplicativo.\\n\\nPara comemorar este momento, realizaremos várias campanhas. Para mais detalhes, consulte os anúncios no jogo e nas nossas redes sociais oficiais.\\n\\n■ Campanha do lançamento oficial\\nPara celebrar o lançamento, vamos realizar minijogos de evento.\\nAo participar deles, você poderá obter \\\"Pijama do Agumon (pernas)\\\" e \\\"Pijama do Gatomon (pernas)\\\".\\n[Período: 15/07/2026 16:00 (UTC+9) ~ 30/09/2026 23:59 (UTC+9)]\\n\\n■ Campanha de pré-registro\\nPara comemorar 1 milhão de pré-registros, distribuiremos os seguintes presentes. Resgate-os em \\\"Presentes\\\" na tela inicial.\\n・ [Amigo] Tai Kamiya e Agumon\\n・ Pijama do Patamon (cabeça), Pijama do Patamon (tronco) e Pijama do Patamon (pernas)\\n・ [Digimon Auxiliar] Gekomon\\n・ [Digimon Auxiliar] Numemon\\n・ DigiEsmeralda x3000\\n・ Bilhetes da Invocação de Cartas de Habilidade x450\\n・ Bilhetes da Invocação Auxiliar x450\\n・ Bilhetes de Holograma x1000\\n・ Semente de DigiCarne boa x10\\n・ Sementes de DigiCarne muito boa x3\\n・ Bit x1.000\\n[Período: 15/07/2026 16:00 (UTC+9) ~ 30/09/2026 23:59 (UTC+9)]\\n\\n* Avisos\\n・ O período e os detalhes de cada campanha podem ser alterados sem aviso prévio.\\n・ Algumas recompensas só podem ser utilizadas após liberar determinados conteúdos.\\n\\nEsperamos que você continue se divertindo com DIGIMON UP.\"},{\"_languageType\":4,\"_title\":\"[공지] <디지몬 UP> 그랜드 오픈!\",\"_message\":\"07/15 16:00에 정식 출시가 시작되었습니다.\\n\\n정식 출시를 기념해 이벤트 및 혜택을 준비하였습니다. \\n각 이벤트의 자세한 내용은 이벤트별 공지 및 인게임, 공식 SNS 등을 확인해 주시기 바랍니다.\\n\\n■ 출시 기념 이벤트\\n출시를 기념해 미니 게임 이벤트를 개최합니다.\\n미니 게임에 참여하여  \u2018아구몬 잠옷(신발)\u2019과  \u2018가트몬 잠옷(신발)\u2019을 획득할 수 있습니다.\\n[개최 기간 : 2026/07/15 16:00 ~ 2026/09/30 23:59]\\n\\n■ 사전 이벤트 보상\\n보상으로 다음 선물을 드립니다. 홈 화면의 \u2018선물\u2019에서 수령해 주시기 바랍니다.\\n・[버디] 야가미 타이치&아구몬\\n・파닥몬 잠옷(머리), 파닥몬 잠옷(의상), 파닥몬 잠옷(신발)\\n・[서포터] 겟코몬\\n・[서포터] 워매몬\\n・디지에메랄드 3000개\\n・스킬 카드 소환 티켓 450장\\n・서포터 소환 티켓 450장\\n・홀로그램 티켓 1000장\\n・좋은 디지고기 씨앗 10개\\n・매우 좋은 디지고기 씨앗 3개\\n・bit 1000개\\n[개최 기간 : 2026/07/15 16:00 ~ 2026/09/30 23:59]\\n\\n\u203B 주의 사항\\n・각종 이벤트 개최 기간 및 내용은 예고 없이 변경될 수 있습니다.\\n・일부 보상은 관련 콘텐츠가 해금된 이후에 사용 가능합니다.\\n\\n앞으로도 \u2018디지몬 UP\u2019에 많은 성원 부탁드립니다.\"},{\"_languageType\":6,\"_title\":\"[Mitteilung] \u201EDIGIMON UP\u201C offiziell gestartet!\",\"_message\":\"Vielen Dank, dass du unser Spiel spielst.\\nHier ist das \u201EDIGIMON UP\u201C-Team.\\n\\nDer Service wurde am 15.07. um 16:00 Uhr (UTC+9) offiziell gestartet.\\n\\nZur Feier des offiziellen Service-Starts findet eine Aktion statt. Weitere Informationen zu den einzelnen Aktionen findest du in den jeweiligen Mitteilungen, im Spiel selbst, auf den offiziellen Social-Media-Accounts usw.\\n\\n■ Aktion zum offiziellen Start\\nZur Feier des Service-Starts findet ein Minispiel-Event statt.\\nWenn du daran teilnimmst, kannst du den \u201EAgumon-Pyjama (Beine)\u201C und den \u201EGatomon-Pyjama (Beine)\u201C erhalten.\\n[Zeitraum: 15.07.2026 um 16:00 Uhr (UTC+9) bis 30.09.2026 um 23:59 Uhr (UTC+9)]\\n\\n■ Vorregistrierungs-Aktion\\nAls Dank für das Erreichen von 1 Million Vorregistrierungen erhältst du folgende Geschenke. Hole sie über \u201EGeschenk\u201C auf dem Startbildschirm ab.\\n・[Kamerad] Taichi Yagami & Agumon\\n・Patamon-Pyjama (Kopf), Patamon-Pyjama (Oberkörper), Patamon-Pyjama (Beine)\\n・[Support-Digimon] Gekkomon\\n・[Support-Digimon] Numemon\\n・3.000 Digi-Smaragde\\n・450 Fähigkeitskartenbeschwörungstickets\\n・450 Supportbeschwörungstickets\\n・1.000 Hologramm-Tickets\\n・10 \u201EGute Digi-Fleischsamen\u201C\\n・3 \u201ESehr gute Digi-Fleischsamen\u201C\\n・1.000 Bits\\n[Zeitraum: 15.07.2026 um 16:00 Uhr (UTC+9) bis 30.09.2026 um 23:59 Uhr (UTC+9)]\\n\\n*Hinweise\\n・Zeitraum und Inhalte der jeweiligen Aktionen können ohne vorherige Ankündigung geändert werden.\\n・Einige Boni können erst nach Freischaltung entsprechender Inhalte genutzt werden.\\n\\nWir danken dir für deine weitere Unterstützung von \u201EDIGIMON UP\u201C.\"},{\"_languageType\":7,\"_title\":\"[Aviso] ¡DIGIMON UP ya está disponible!\",\"_message\":\"Gracias por jugar DIGIMON UP.\\nSomos el equipo de administración.\\n\\nEl servicio oficial ha comenzado a partir de\\n\\n15/07/2026 16:00 (UTC+9).\\n\\nPara celebrar el inicio del servicio oficial, llevaremos a cabo varias campañas. Para conocer los detalles de cada campaña, consulta los avisos correspondientes, así como dentro del juego y nuestras redes sociales oficiales.\\n\\n■ Campaña de lanzamiento\\nPara celebrar el inicio del servicio, organizaremos un evento de minijuego.\\nAl participar, podrás obtener \\\"Pijama de Agumon (pies)\\\" y \\\"Pijama de Gatomon (pies)\\\".\\n[Periodo de la campaña: 15/07/2026 16:00 (UTC+9) ~ 30/09/2026 23:59 (UTC+9)]\\n\\n■ Campaña de registros previos\\nComo agradecimiento por haber superado el millón de registros previos, te regalamos lo siguiente. Recíbanlo desde la sección \\\"Regalos\\\" de la pantalla de inicio.\\n・[Colega] Tai Kamiya y Agumon\\n・Pijama de Patamon (cabeza), pijama de Patamon (torso), pijama de Patamon (pies)\\n・[Digimon de apoyo] Gekkomon\\n・[Digimon de apoyo] Numemon\\n・3000 Digiesmeraldas\\n・450 Tickets de sorteo de cartas de habilidad\\n・450 Tickets de sorteo de apoyo\\n・1000 Tickets de holograma\\n・10 Buenas semillas de Digicarne\\n・3 Semillas de Digicarne excelentes\\n・1 000 Bits\\n[Periodo de la campaña: 15/07/2026 16:00 (UTC+9) ~ 30/09/2026 23:59 (UTC+9)]\\n\\n\u203B Notas importantes\\n・El periodo de duración y el contenido de las distintas campañas pueden cambiar sin previo aviso.\\n・Algunas recompensas podrán utilizarse una vez que se desbloqueen los contenidos relacionados.\\n\\nEsperamos que sigan disfrutando de DIGIMON UP.\"}]}},{\"_noticeId\":\"a90d6331-e0cc-4568-8f6a-ee626bf11230\",\"_type\":2,\"_contents\":{\"_list\":[{\"_languageType\":6,\"_title\":\"SP-Supportbeschwörung \u201EWarGreymon\u201C gestartet!\",\"_message\":\"Vielen Dank, dass du unser Spiel spielst.\\n Hier ist das \u201EDIGIMON UP\u201C-Team.\\n \\n Seit dem 07.15. um 16:00 Uhr (UTC+9) ist die SP-Supportbeschwörung \u201EWarGreymon\u201C verfügbar.\\n  \\n [Zeitraum: 15.07.2026 um 16:00 Uhr (UTC+9) bis 05.08.2026 um 14:59 Uhr (UTC+9)]\\n \\n ■ Neue SP-Support-Digimon\\n ・[EX+]: WarGreymon (SP)\\n  \\n ▼ Beschwörung\\n ・Mit jeder Beschwörung verringert sich die Anzahl der nötigen Versuche bis zum garantierten Pickup um 1.\\n ・Beträgt die Anzahl der nötigen Versuche 0, erscheint das Pickup-Ziel auf jeden Fall.\\n ・Ist das Pickup-Ziel erschienen, wird die Anzahl der nötigen Versuche auf 200 zurückgesetzt.\\n \\n *Hinweise\\n ・Die Dropraten kannst du unter \u201EDropraten anzeigen\u201C auf dem jeweiligen Beschwörungs-Bildschirm einsehen.\\n ・Die Pickup-Punkte dieser Beschwörung werden nicht mit anderen Beschwörungen geteilt. Nicht verwendete Pickup-Punkte verfallen nach Ende des Pickup-Zeitraums.\\n ・Dropraten sind auf die achte Dezimalstelle abgerundet. Der Gesamtwert ergibt somit unter bestimmten Umständen nicht 100%.\\n ・In dieser Beschwörung kann derselbe SP-Support, Support oder dieselbe Fähigkeitskarte mehrmals vorkommen.\\n ・Je nach Verbindungsqualität kann es vorkommen, dass die Beschwörungsanimation übersprungen oder nicht korrekt dargestellt wird. Die Beschwörung selbst wird jedoch ordnungsgemäß abgeschlossen. Bitte überprüfe deinen Besitzstatus.\\n ・Sollte die App während der Animation abstürzen, versuche bitte, andere laufende Apps zu schließen.\\n ・Die SP-Support-Digimon dieser Beschwörung können in Zukunft erneut auftauchen.\\n ・Zeitraum und Inhalte können ohne vorherige Ankündigung geändert werden.\\n ・Einige Digimon können erst nach Freischaltung entsprechender Inhalte genutzt werden.\\n \\n  Wir danken dir für deine weitere Unterstützung von \u201EDIGIMON UP\u201C.\"},{\"_languageType\":2,\"_title\":\"SP支援型扭蛋\u201C战斗暴龙兽\u201D登场！\",\"_message\":\"感谢您一直以来的支持与喜爱。\\n 这里是《数码宝贝 UP》运营团队。\\n \\n SP支援型扭蛋\u201C战斗暴龙兽\u201D已于07/15 16:00(UTC+9)起登场。\\n \\n 〔举办期间：2026/07/15 16:00(UTC+9) ~ 2026/08/05 14:59(UTC+9)〕\\n \\n ■新SP支援型介绍\\n ·[EX+]：战斗暴龙兽（SP Ver.）\\n \\n ▼关于扭蛋\\n ・每抽取1次扭蛋，距离保证获得精选的所需次数就会减少1次。\\n ・当所需次数为0次时，精选内容就必定会出现。\\n ・当精选内容出现后，所需次数就会重置为200次。\\n \\n \u203B注意事项\\n ·各项目的出现机率，请至各扭蛋画面的\u201C出现机率\u201D确认。\\n ・此扭蛋的精选点数无法与其他扭蛋共用。精选期间结束后，未使用的精选点数无法继承，将直接消失。\\n ・各项目的出现机率为小数点后第8位无条件舍去，因此总和可能不会是100%。\\n ・此扭蛋内可能会出现重复SP支援型、支援型或技能卡片。\\n ·根据网络连线状况，有可能出现扭蛋动画被跳过或无法正常显示的情形。此情形下扭蛋已正常完成抽取，请确认您的持有状况。\\n ·若于播放动画时发生应用程序强制关闭的情形，请尝试关闭其他正在执行的应用程序。\\n ·本扭蛋的SP支援型今后有可能再次推出。\\n ·登场期间与内容有可能未经预告径行变更。\\n ·部分数码宝贝在解锁相关内容后方可使用。\\n \\n 今后还请继续支持《数码宝贝 UP》。\"},{\"_languageType\":3,\"_title\":\"SP支援型轉蛋「戰鬥暴龍獸」登場！\",\"_message\":\"感謝您一直以來的支持與喜愛。\\n 這裡是《數碼寶貝 UP》營運團隊。\\n \\n SP支援型轉蛋「戰鬥暴龍獸」已於07/15 16:00(UTC+9)起登場。\\n \\n 〔舉辦期間：2026/07/15 16:00(UTC+9) ~ 2026/08/05 14:59(UTC+9)〕\\n \\n ■新SP支援型介紹\\n \u2027[EX+]：戰鬥暴龍獸（SP Ver.）\\n \\n ▼關於轉蛋\\n ・ガシャを1回引くごとに、ピックアップ確定までの必要回数が1回ずつ減少します。\\n ・必要回数が0回になると、ピックアップ対象が必ず出現します。\\n ・ピックアップ対象が出現した場合、必要回数は200回にリセットされます。\\n \\n \u203B注意事項\\n \u2027各項目的出現機率，請至各轉蛋畫面的「顯示出現機率」確認。\\n ・此轉蛋的精選點數無法與其他轉蛋共用。精選期間結束後，未使用的精選點數無法繼承，將直接消失。\\n ・各項目的出現機率為小數點後第8位無條件捨去，因此總和可能不會是100%。\\n ・此轉蛋內可能會出現重複SP支援型、支援型或技能卡片。\\n \u2027根據網路連線狀況，有可能出現轉蛋動畫被跳過或無法正常顯示的情形。此情形下轉蛋已正常完成抽取，請確認您的持有狀況。\\n \u2027若於播放動畫時發生應用程式強制關閉的情形，請嘗試關閉其他正在執行的應用程式。\\n \u2027本轉蛋的SP支援型今後有可能再次推出。\\n \u2027登場期間與內容有可能未經預告逕行變更。\\n \u2027部分數碼寶貝在解鎖相關內容後方可使用。\\n \\n 今後還請繼續支持《數碼寶貝 UP》。\"},{\"_languageType\":5,\"_title\":\"Lancement de l'invoc. de soutien SP « WarGreymon » !\",\"_message\":\"Nous vous remercions de jouer à notre jeu.\\n Nous sommes l'équipe de gestion de DIGIMON UP. \\n \\n L'invocation de soutien SP « WarGreymon » a été lancée le 15/07 à 16 h 00 (UTC +9)\\n  \\n [Période de l'événement : du 15/07/2026 à 16 h 00 (UTC +9) au 05/08/2026 à 14 h 59 (UTC +9)]\\n \\n ■ Présentation du nouveau soutien SP\\n - [EX+] : WarGreymon (ver. SP)\\n  \\n ▼À propos des invocations\\n - Chaque fois que vous effectuez une invocation, le nombre d'invocations restantes nécessaires avant l'apparition de l'élément en vedette garanti diminue de 1.\\n - L'élément en vedette apparaît obligatoirement quand le nombre d'invocations nécessaires atteint 0.\\n - Une fois que l'élément en vedette est apparu, le nombre d'invocations nécessaires est réinitialisé à 200.\\n \\n * Remarques\\n - Consultez le menu « Affichage des taux d'obtention » à l'écran de chaque invocation pour connaître son taux d'obtention.\\n - Les points « En vedette » de cette invocation ne sont pas partagés avec les autres invocations. Une fois la période « En vedette » terminée, les points « En vedette » non utilisés ne seront pas gardés et disparaîtront.\\n - Les taux d'obtention sont arrondis au dix-millionième inférieur le plus proche. Le nombre total des taux d'obtention listés peut ne pas être égal à 100 %.\\n - Plus d'un exemplaire du même soutien SP, soutien ou carte de capacité peut apparaître lors de cette invocation.\\n - L'animation de l'invocation peut être passée ou ne pas s'afficher correctement en fonction de votre connexion, mais l'invocation sera bel et bien effectuée, donc surveillez votre inventaire.\\n - Si cette application se ferme subitement lors de la lecture d'une animation, veuillez essayer de quitter les autres applications en cours d'exécution.\\n - Le soutien SP de cette invocation pourrait être à nouveau disponible à l'avenir.\\n - La période et le contenu de l'invocation sont susceptibles d'être modifiés sans préavis.\\n - Certains Digimon ne pourront être utilisés qu'après le déblocage du contenu associé.\\n \\n  Nous espérons que vous continuerez de soutenir DIGIMON UP.\"},{\"_languageType\":0,\"_title\":\"SP Support Summon: WarGreymon!\",\"_message\":\" As of 07/15 16:00 (UTC +9), WarGreymon SP Support Summon is underway.\\n \\n [Event Period]: 07/15/2026 16:00 (UTC +9) - 08/05/2026 14:59 (UTC +9)\\n \\n ■ Introducing New SP Supports:\\n \u2022 [EX+]: WarGreymon (SP Ver.)\\n \\n ▼Summon Details:\\n ・Each summon increases your Deluxe Points for this Summon by 1.\\n ・Upon reaching 0 Deluxe Points, the featured Deluxe item will be guaranteed to appear.\\n ・If the featured Deluxe item is summoned, your Deluxe Points will reset to 200.\\n \\n * CAUTION:\\n \u2022 For supply ratio details, check the \\\"Supply Ratio Display\\\" on the respective Summon screen.\\n ・After the Deluxe Summon period ends, any unused Deluxe Points will expire and will not carry over.\\n ・The drop rates are rounded down to the eighth decimal place. The total number of the listed drop rates may not add up to 100%.\\n ・Duplicate SP Supports, Supports, or Skill Cards may appear from this Summon.\\n \u2022 Depending on your connection status, the Summon animation may be skipped or may not display correctly. However, the Summon itself will complete normally, so please check your inventory.\\n \u2022 If the app crashes during an animation, please try closing any other apps running on your device.\\n \u2022 SP Supports featured in this Summon may appear again in the future.\\n \u2022 Event period and details are subject to change without notice.\\n \u2022 Some Digimon may only be used after unlocking certain contents.\\n \\n We hope you continue to enjoy DIGIMON UP!\"},{\"_languageType\":8,\"_title\":\"Invocação Auxiliar SP \\\"WarGreymon\\\" em curso!\",\"_message\":\"Obrigado por jogar nosso aplicativo.\\n Aqui é a Equipe de Administração do DIGIMON UP.\\n \\n Às 16:00 de 15/07 (UTC+ 9), lançamos a Invocação Auxiliar SP \\\"WarGreymon\\\".\\n \\n [Período: 15/07/2026 16:00 (UTC+9) ~ 05/08/2026 14:59 (UTC+9)]\\n \\n ■ Apresentação de novo Auxiliar SP\\n ・ [EX+]:WarGreymon (Ver. SP)\\n \\n ▼ Sobre a Invocação\\n ・Cada vez que você roda a Invocação, o número necessário de tentativas até garantir o item em destaque é reduzido em 1.\\n ・Quando o número necessário de tentativas chegar a 0, o item em destaque aparecerá garantidamente.\\n ・Ao obter o item em destaque, o contador de tentativas necessárias é reiniciado para 200.\\n \\n * Observações\\n ・ Para mais informações sobre as chances, consulte \\\"visualizar chances\\\" na tela da Invocação.\\n ・Os Pontos de Destaque obtidos nesta Invocação não são compartilhados com outras Invocações. Quando o período do Destaque terminar, os Pontos de Destaque não usados não serão transferidos e serão perdidos.\\n ・A taxa de obtenção é arredondada para baixo na sétima casa decimal. A soma das taxas de obtenção listadas pode não resultar em 100%.\\n Esta Invocação pode conceder Digimon Auxiliares SP, Auxiliares e Cartas de Habilidade repetidos. \\n ・ Dependendo da sua conexão, as animações da Invocação podem não ser exibidas corretamente ou ser puladas. Porém, a Invocação em si acontecerá normalmente. Para confirmar, verifique o seu inventário.\\n ・ Se o aplicativo fechar sozinho durante as animações, tente fechar outros aplicativos que estejam abertos em segundo plano.\\n ・ Os Auxiliares SP disponíveis nesta Invocação podem voltar a aparecer no futuro.\\n ・ O período e os detalhes podem ser alterados sem aviso prévio.\\n ・ Alguns Digimon só podem ser utilizados após liberar determinados conteúdos.\\n \\n Esperamos que você continue se divertindo com DIGIMON UP.\"},{\"_languageType\":7,\"_title\":\"¡Ya disponible el sorteo de apoyo SP WarGreymon!\",\"_message\":\"Gracias por jugar DIGIMON UP.\\n Somos el equipo de administración.\\n \\n A partir de las 16:00 del 15/07 (UTC+9), estará disponible el sorteo de apoyo SP WarGreymon.\\n  \\n [Periodo de la campaña: 15/07/2026 16:00 (UTC+9) ~ 05/08/2026 14:59 (UTC+9)]\\n \\n ■ Presentación del nuevo apoyo SP\\n  ・[EX+]:WarGreymon (Ver. SP)\\n  \\n ▼ Sobre los sorteos\\n ・Cada vez que realices un intento, el número necesario para obtener el personaje destacado se reduce en 1.\\n ・Cuando llegue a 0, el personaje destacado aparecerá de forma garantizada.\\n ・Cuando aparezca, el contador de intentos necesarios volverá a 200.\\n \\n \u203B Notas importantes\\n  ・ Puedes consultar el ratio de aparición en Ver probabilidades dentro de la pantalla de cada sorteo.\\n  ・Los puntos de sorteo destacado de este sorteo no se comparten con otros sorteos. Una vez terminado el periodo del sorteo destacado, los puntos de sorteo destacado que no hayan sido utilizados desaparecerán sin ser diferidos.\\n ・Las tasas de obtención se redondean a la baja al octavo decimal más próximo. Es posible que el número total de las tasas de obtención enumeradas no sumen el 100 %.\\n ・En este Sorteo, es posible que aparezcan Apoyos SP, Apoyos o Cartas de habilidad duplicados.\\n ・ Dependiendo del estado de la conexión, es posible que las animaciones del sorteo se omitan o no se muestren correctamente. De todas formas, el sorteo se habrá completado con normalidad, así que revisa tu inventario.\\n  ・ Si la aplicación se cierra inesperadamente durante la reproducción de una animación, cierra otras aplicaciones que tengas abiertas y vuelve a intentarlo.\\n  ・ Los apoyos SP de este sorteo podrían volver a aparecer en el futuro.\\n  ・ Las fechas y el contenido podrían modificarse sin previo aviso.\\n  ・Algunos Digimon estarán disponibles una vez que se desbloqueen los contenidos relacionados.\\n \\n  Esperamos que sigas disfrutando de DIGIMON UP.\"},{\"_languageType\":4,\"_title\":\"신규 SP 서포터 [워그레이몬] 등장!\",\"_message\":\" 07/15 16:00부터 SP 서포터 소환에 [워그레이몬]이 등장합니다.\\n \\n [개최 기간 : 2026/07/15 16:00 ~ 2026/08/05 14:59]\\n \\n ■ 픽업 대상\\n  · [EX+]: 워그레이몬 (SP Ver.)\\n  \\n ▼ 소환에 대해\\n  · 1회 소환 시 마다 픽업 확정까지의 필요한 소환 횟수가 1씩 차감됩니다.\\n  · 필요한 소환 횟수가 0회가 될 경우 해당 픽업 소환의 픽업 소환물이 확정적으로 출현합니다.\\n  · 소환으로 픽업 소환물이 출현한 경우, 픽업 확정까지의 필요한 소환 횟수 200회로 초기화됩니다.\\n \\n  \u203B 주의 사항\\n  · 출현 확률은 각 소환의 '확률 정보 표시' 목록을 확인해 주시기 바랍니다.\\n  · 본 소환의 픽업 포인트는 다른 소환의 픽업 포인트와 공유되지 않으며, 픽업 기간이 종료되면 이월되지 않고 사라집니다.\\n  · 각각의 출현 확률은 소수점 8번째 자리에서 버림하여 표시되므로 합계치가 100%가 되지 않을 수도 있습니다.\\n  · 본 소환에서는 중복되는 SP 서포터 혹은 서포터, 스킬 카드가 출현할 가능성이 있습니다.\\n  · 통신 상태에 따라서는 소환의 연출이 건너뛰어지거나 정상적으로 표시되지 않을 수 있지만, 소환이 완료된 상태이므로 보유 상황을 확인해 주십시오.\\n  · 애니메이션 재생 시에 앱이 강제 종료되는 경우, 실행 중인 다른 앱을 종료한 후 다시 시도해주세요.\\n  · 본 소환 대상의 SP 서포터는 추후 재등장할 수 있습니다.\\n  · 개최 기간 및 내용은 예고 없이 변경될 수 있습니다.\\n  · 일부 디지몬은 관련 컨텐츠가 해금된 이후에 사용 가능합니다.\\n \\n  앞으로도 '디지몬 UP'에 많은 성원 부탁드립니다.\"},{\"_languageType\":1,\"_title\":\"新SPサポーターデジモン「ウォーグレイモン」登場！\",\"_message\":\" 07/15 16:00より、SPサポーターガシャに「ウォーグレイモン」が登場いたしました。\\n \\n [開催期間：2026/07/15 16:00 ~ 2026/08/05 14:59]\\n \\n ■ ピックアップ対象\\n ・[EX+]：ウォーグレイモン (SP Ver.)\\n \\n ▼ ガシャについて\\n ・ガシャを1回引くごとに、ピックアップ確定までの必要回数が1回ずつ減少します。\\n ・必要回数が0回になると、ピックアップ対象が必ず出現します。\\n ・ピックアップ対象が出現した場合、必要回数は200回にリセットされます。\\n \\n \u203B 注意事項\\n ・提供割合につきましては、各ガシャ画面の「提供割合表示」よりご確認ください。\\n ・本ガシャのピックアップポイントは他のガシャと共有されません。ピックアップ期間終了後、未使用のピックアップポイントは持ち越されず消滅します。\\n ・それぞれの提供割合は、小数第8位を切り捨てて表示しているため、合計値が100％にならない場合があります。\\n ・本ガシャからは重複するSPサポーターもしくはサポーター、スキルカードが出現する可能性があります。\\n ・通信状況によっては、ガシャの演出がスキップされることや正常に表示されない場合がありますが、ガシャ自体は正常に完了しておりますため、所持状況をご確認ください。\\n ・アニメーション再生時にアプリが強制終了してしまう場合は、起動中の他アプリの終了等をお試しください。\\n ・本ガシャの対象SPサポーターは、今後再登場する場合があります。\\n ・開催期間および内容は、予告なく変更する場合があります。\\n ・一部デジモンは関連コンテンツの解放後に使用可能となります。\\n \\n 今後とも『デジモンUP』をよろしくお願いいたします。\"}]}},{\"_noticeId\":\"7ef4a35e-ed81-4043-bbd9-c056ff80b8c8\",\"_type\":2,\"_contents\":{\"_list\":[{\"_languageType\":0,\"_title\":\"Buddy Summon: Tai Kamiya & Agumon!\",\"_message\":\"As of 07/15 16:00 (UTC +9), Tai Kamiya & Agumon Buddy Summon is underway.\\n \\n [Event Period]: 07/15/2026 16:00 (UTC +9) - 08/05/2026 14:59 (UTC +9)\\n \\n ■ Pick Up:\\n \u2022 [EX+]: Tai Kamiya & Agumon \\n \\n ▼Summon Details:\\n ・Each summon increases your Deluxe Points for this Summon by 1.\\n ・Upon reaching 0 Deluxe Points, the featured Deluxe item will be guaranteed to appear.\\n ・If the featured Deluxe item is summoned, your Deluxe Points will reset to 200. \\n \\n * CAUTION:\\n \u2022 For supply ratio details, check the \\\"Supply Ratio Display\\\" on the respective Summon screen.\\n ・After the Deluxe Summon period ends, any unused Deluxe Points will expire and will not carry over.\\n ・The drop rates are rounded down to the eighth decimal place. The total number of the listed drop rates may not add up to 100%.\\n ・Duplicate Buddies, Supports, or Skill Cards may appear in this Summon.\\n \u2022 Depending on your connection status, the Summon animation may be skipped or may not display correctly. However, the Summon itself will complete normally, so please check your inventory.\\n \u2022 If the app crashes during an animation, please try closing any other apps running on your device.\\n \u2022 Buddies featured in this Summon may appear again in the future.\\n \u2022 Event period and details are subject to change without notice.\\n \u2022 Some Digimon may only be used after unlocking certain contents.\\n \\n We hope you continue to enjoy DIGIMON UP!\"},{\"_languageType\":1,\"_title\":\"新バディ「八神太一&アグモン」登場！\",\"_message\":\" 07/15 16:00より、バディガシャに「八神太一&アグモン」が登場いたしました。\\n \\n [開催期間：2026/07/15 16:00 ~ 2026/08/05 14:59]\\n \\n ■ ピックアップ対象\\n ・[EX+]：八神太一＆アグモン\\n \\n ▼ ガシャについて\\n ・ガシャを1回引くごとに、ピックアップ確定までの必要回数が1回ずつ減少します。\\n ・必要回数が0回になると、ピックアップ対象が必ず出現します。\\n ・ピックアップ対象が出現した場合、必要回数は200回にリセットされます。\\n \\n \u203B 注意事項\\n ・提供割合につきましては、各ガシャ画面の「提供割合表示」よりご確認ください。\\n ・本ガシャのピックアップポイントは他のガシャと共有されません。ピックアップ期間終了後、未使用のピックアップポイントは持ち越されず消滅します。\\n ・それぞれの提供割合は、小数第8位を切り捨てて表示しているため、合計値が100％にならない場合があります。\\n ・本ガシャからは重複するバディもしくはサポーター、スキルカードが出現する可能性があります。\\n ・通信状況によっては、ガシャの演出がスキップされることや正常に表示されない場合がありますが、ガシャ自体は正常に完了しておりますため、所持状況をご確認ください。\\n ・アニメーション再生時にアプリが強制終了してしまう場合は、起動中の他アプリの終了等をお試しください。\\n ・本ガシャの対象バディは、今後再登場する場合があります。\\n ・開催期間および内容は、予告なく変更する場合があります。\\n ・一部デジモンは関連コンテンツの解放後に使用可能となります。\\n \\n 今後とも『デジモンUP』をよろしくお願いいたします。\"},{\"_languageType\":7,\"_title\":\"¡Ya está aquí el sorteo de colegas Taichi Yagami y Agumon!\",\"_message\":\"Gracias por jugar DIGIMON UP.\\n Somos el equipo de administración.\\n \\n A partir de las 16:00 del 15/07 (UTC+9), estará disponible el sorteo de colegas Tai Yagami y Agumon.\\n  \\n [Periodo de la campaña: 15/07/2026 16:00 (UTC+9) ~ 05/08/2026 14:59 (UTC+9)] \\n \\n ■ Presentación del nuevo colega\\n  ・[EX+]:Tai Kamiya y Agumon\\n \\n ▼ Sobre los sorteos\\n ・Cada vez que realices un intento, el número necesario para obtener el personaje destacado se reduce en 1.\\n ・Cuando llegue a 0, el personaje destacado aparecerá de forma garantizada.\\n ・Cuando aparezca, el contador de intentos necesarios volverá a 200.\\n \\n \u203B Notas importantes\\n  ・ Puedes consultar el ratio de aparición en Ver probabilidades dentro de la pantalla de cada sorteo.\\n  ・Los puntos de sorteo destacado de este sorteo no se comparten con otros sorteos. Una vez terminado el periodo del sorteo destacado, los puntos de sorteo destacado que no hayan sido utilizados desaparecerán sin ser diferidos.\\n ・Las tasas de obtención se redondean a la baja al octavo decimal más próximo. Es posible que el número total de las tasas de obtención enumeradas no sumen el 100 %.\\n ・En este Sorteo, es posible que aparezcan Colegas, Apoyos o Cartas de habilidad duplicados.\\n ・ Dependiendo del estado de la conexión, es posible que las animaciones del sorteo se omitan o no se muestren correctamente. De todas formas, el sorteo se habrá completado con normalidad, así que revisa tu inventario.\\n  ・ Si la aplicación se cierra inesperadamente durante la reproducción de una animación, cierra otras aplicaciones que tengas abiertas y vuelve a intentarlo.\\n  ・ Los colegas de este sorteo podrían volver a aparecer en el futuro.\\n  ・ Las fechas y el contenido podrían modificarse sin previo aviso.\\n  ・Algunos Digimon estarán disponibles una vez que se desbloqueen los contenidos relacionados.\\n \\n Esperamos que sigas disfrutando de DIGIMON UP.\"},{\"_languageType\":6,\"_title\":\"Kameradbeschwörung \u201ETaichi Yagami & Agumon\u201C gestartet!\",\"_message\":\"Vielen Dank, dass du unser Spiel spielst.\\n Hier ist das \u201EDIGIMON UP\u201C-Team.\\n \\n Seit dem 15.07. um 16:00 Uhr (UTC+9) ist die Kameradbeschwörung \u201ETaichi Yagami & Agumon\u201C verfügbar.\\n  \\n [Zeitraum: 15.07.2026 um 16:00 Uhr (UTC+9) bis 05.08.2026 um 14:59 Uhr (UTC+9)]\\n \\n ■ Neue Kameraden\\n ・[EX+]: Taichi Yagami & Agumon \\n \\n ▼ Beschwörung\\n ・Mit jeder Beschwörung verringert sich die Anzahl der nötigen Versuche bis zum garantierten Pickup um 1.\\n ・Beträgt die Anzahl der nötigen Versuche 0, erscheint das Pickup-Ziel auf jeden Fall.\\n ・Ist das Pickup-Ziel erschienen, wird die Anzahl der nötigen Versuche auf 200 zurückgesetzt. \\n \\n *Hinweise\\n ・Die Dropraten kannst du unter \u201EDropraten anzeigen\u201C auf dem jeweiligen Beschwörungs-Bildschirm einsehen.\\n ・Die Pickup-Punkte dieser Beschwörung werden nicht mit anderen Beschwörungen geteilt. Nicht verwendete Pickup-Punkte verfallen nach Ende des Pickup-Zeitraums.\\n ・Dropraten sind auf die achte Dezimalstelle abgerundet. Der Gesamtwert ergibt somit unter bestimmten Umständen nicht 100%.\\n ・In dieser Beschwörung kann derselbe Kamerad, Support oder dieselbe Fähigkeitskarte mehrmals vorkommen.\\n ・Je nach Verbindungsqualität kann es vorkommen, dass die Beschwörungsanimation übersprungen oder nicht korrekt dargestellt wird. Die Beschwörung selbst wird jedoch ordnungsgemäß abgeschlossen. Bitte überprüfe deinen Besitzstatus.\\n ・Sollte die App während der Animation abstürzen, versuche bitte, andere laufende Apps zu schließen.\\n ・Die Kameraden dieser Beschwörung können in Zukunft erneut auftauchen.\\n ・Zeitraum und Inhalte können ohne vorherige Ankündigung geändert werden.\\n ・Einige Digimon können erst nach Freischaltung entsprechender Inhalte genutzt werden.\\n \\n Wir danken dir für deine weitere Unterstützung von \u201EDIGIMON UP\u201C.\"},{\"_languageType\":8,\"_title\":\"Invocação de Amigos \\\"Taichi Kamiya e Agumon\\\" em curso!\",\"_message\":\"Obrigado por jogar nosso aplicativo.\\n Aqui é a Equipe de Administração do DIGIMON UP.\\n \\n Às 16:00 de 15/07 (UTC +9), lançamos a Invocação de Amigos \\\"Taichi Kamiya e Agumon\\\".\\n \\n [Período: 15/07/2026 16:00 (UTC+9) ~ 05/08/2026 14:59 (UTC+9)]\\n \\n ■ Apresentação do novo Amigo\\n ・ [EX+]:Tai Kamiya e Agumon\\n \\n ▼ Sobre a Invocação\\n ・Cada vez que você roda a Invocação, o número necessário de tentativas até garantir o item em destaque é reduzido em 1.\\n ・Quando o número necessário de tentativas chegar a 0, o item em destaque aparecerá garantidamente.\\n ・Ao obter o item em destaque, o contador de tentativas necessárias é reiniciado para 200.\\n \\n * Observações\\n ・ Para mais informações sobre as chances, consulte \\\"visualizar chances\\\" na tela da Invocação.\\n ・Os Pontos de Destaque obtidos nesta Invocação não são compartilhados com outras Invocações. Quando o período do Destaque terminar, os Pontos de Destaque não usados não serão transferidos e serão perdidos.\\n ・A taxa de obtenção é arredondada para baixo na sétima casa decimal. A soma das taxas de obtenção listadas pode não resultar em 100%.\\n ・Esta Invocação pode conceder Amigos, Digimon Auxiliares e Cartas de Habilidade repetidos.\\n ・ Dependendo da sua conexão, as animações da Invocação podem não ser exibidas corretamente ou ser puladas. Porém, a Invocação em si acontecerá normalmente. Para confirmar, verifique o seu inventário.\\n ・ Se o aplicativo fechar sozinho durante as animações, tente fechar outros aplicativos que estejam abertos em segundo plano.\\n ・ Os Amigos disponíveis nesta Invocação podem voltar a aparecer no futuro.\\n ・ O período e os detalhes podem ser alterados sem aviso prévio.\\n ・ Alguns Digimon só podem ser utilizados após liberar determinados conteúdos.\\n \\n Esperamos que você continue se divertindo com DIGIMON UP.\"},{\"_languageType\":2,\"_title\":\"搭档扭蛋\u201C八神太一＆亚古兽\u201D登场！\",\"_message\":\"感谢您一直以来的支持与喜爱。\\n 这里是《数码宝贝 UP》运营团队。\\n \\n 搭档扭蛋\u201C八神太一＆亚古兽\u201D已于07/15 16:00(UTC+9)起登场。\\n \\n 〔举办期间：2026/07/15 16:00(UTC+9) ~ 2026/08/05 14:59(UTC+9)〕\\n \\n ■新搭档介绍\\n ·[EX+]：八神太一＆亚古兽\\n \\n ▼关于扭蛋\\n ・每抽取1次扭蛋，距离保证获得精选的所需次数就会减少1次。\\n ・当所需次数为0次时，精选内容就必定会出现。\\n ・当精选内容出现后，所需次数就会重置为200次。\\n \\n \u203B注意事项\\n ·各项目的出现机率，请至各扭蛋画面的\u201C出现机率\u201D确认。\\n ・此扭蛋的精选点数无法与其他扭蛋共用。精选期间结束后，未使用的精选点数无法继承，将直接消失。\\n ・各项目的出现机率为小数点后第8位无条件舍去，因此总和可能不会是100%。\\n ・此扭蛋内可能会出现重复搭档、支援型或技能卡片。\\n ·根据网络连线状况，有可能出现扭蛋动画被跳过或无法正常显示的情形。此情形下扭蛋已正常完成抽取，请确认您的持有状况。\\n ·若于播放动画时发生应用程序强制关闭的情形，请尝试关闭其他正在执行的应用程序。\\n ·本扭蛋的搭档今后有可能再次推出。\\n ·登场期间与内容有可能未经预告径行变更。\\n ·部分数码宝贝在解锁相关内容后方可使用。\\n \\n 今后还请继续支持《数码宝贝 UP》。\"},{\"_languageType\":3,\"_title\":\"搭檔轉蛋「八神太一＆亞古獸」登場！\",\"_message\":\"感謝您一直以來的支持與喜愛。\\n 這裡是《數碼寶貝 UP》營運團隊。\\n \\n 搭檔轉蛋「八神太一＆亞古獸」已於07/15 16:00(UTC+9)起登場。\\n \\n 〔舉辦期間：2026/07/15 16:00(UTC+9) ~ 2026/08/05 14:59(UTC+9)〕\\n \\n ■新搭檔介紹\\n \u2027[EX+]：八神太一＆亞古獸\\n \\n ▼關於轉蛋\\n ・每抽取1次轉蛋，距離保證獲得精選所需次數將減少1次。\\n ・當所需次數為0次時，必定出現精選內容。\\n ・當精選內容出現後，所需次數將重置為200次。\\n \\n \u203B注意事項\\n \u2027各項目的出現機率，請至各轉蛋畫面的「顯示出現機率」確認。\\n ・此轉蛋的精選點數無法與其他轉蛋共用。精選期間結束後，未使用的精選點數無法繼承，將直接消失。\\n ・各項目的出現機率為小數點後第8位無條件捨去，因此總和可能不會是100%。\\n ・此轉蛋內可能會出現重複搭檔、支援型或技能卡片。\\n \u2027根據網路連線狀況，有可能出現轉蛋動畫被跳過或無法正常顯示的情形。此情形下轉蛋已正常完成抽取，請確認您的持有狀況。\\n \u2027若於播放動畫時發生應用程式強制關閉的情形，請嘗試關閉其他正在執行的應用程式。\\n \u2027本轉蛋的搭檔今後有可能再次推出。\\n \u2027登場期間與內容有可能未經預告逕行變更。\\n \u2027部分數碼寶貝在解鎖相關內容後方可使用。\\n \\n 今後還請繼續支持《數碼寶貝 UP》。\"},{\"_languageType\":5,\"_title\":\"Lancement de l'invoc. de camarade « Taichi Yagami et Agumon » !\",\"_message\":\"Nous vous remercions de jouer à notre jeu.\\n Nous sommes l'équipe de gestion de DIGIMON UP. \\n \\n L'invocation de camarade « Taichi Yagami et Agumon » a été lancée le 15/07 à 16 h 00 (UTC +9)\\n  \\n [Période de l'événement : du 15/07/2026 à 16 h 00 (UTC +9) au 05/08/2026 à 14 h 59 (UTC +9)]\\n \\n ■ Présentation du nouveau camarade\\n - [EX+] : Taichi Yagami et Agumon\\n \\n ▼À propos des invocations\\n - Chaque fois que vous effectuez une invocation, le nombre d'invocations restantes nécessaires avant l'apparition de l'élément en vedette garanti diminue de 1.\\n - L'élément en vedette apparaît obligatoirement quand le nombre d'invocations nécessaires atteint 0.\\n - Une fois que l'élément en vedette est apparu, le nombre d'invocations nécessaires est réinitialisé à 200.\\n \\n * Remarques\\n  - Consultez le menu « Affichage des taux d'obtention » à l'écran de chaque invocation pour connaître son taux d'obtention.\\n  - Les points « En vedette » de cette invocation ne sont pas partagés avec les autres invocations. Une fois la période « En vedette » terminée, les points « En vedette » non utilisés ne seront pas gardés et disparaîtront.\\n  - Les taux d'obtention sont arrondis au dix-millionième inférieur le plus proche. Le nombre total des taux d'obtention listés peut ne pas être égal à 100 %.\\n  - Plus d'un exemplaire du même camarade, soutien ou carte de capacité peut apparaître lors de cette invocation.\\n - L'animation de l'invocation peut être passée ou ne pas s'afficher correctement en fonction de votre connexion, mais l'invocation sera bel et bien effectuée, donc surveillez votre inventaire.\\n - Si cette application se ferme subitement lors de la lecture d'une animation, veuillez essayer de quitter les autres applications en cours d'exécution.\\n - Le camarade de cette invocation pourrait être à nouveau disponible à l'avenir.\\n - La période et le contenu de l'invocation sont susceptibles d'être modifiés sans préavis.\\n - Certains Digimon ne pourront être utilisés qu'après le déblocage du contenu associé.\\n \\n Nous espérons que vous continuerez de soutenir DIGIMON UP.\"},{\"_languageType\":4,\"_title\":\"신규 버디 [야가미 타이치&아구몬] 등장!\",\"_message\":\" 07/15 16:00부터 버디 소환에 [야가미 타이치&아구몬]이 등장합니다.\\n \\n [개최 기간 : 2026/07/15 16:00 ~ 2026/08/05 14:59]\\n \\n ■ 픽업 대상\\n  · [EX+]: 야가미 타이치&아구몬\\n \\n ▼ 소환에 대해\\n  · 1회 소환 시 마다 픽업 확정까지의 필요한 소환 횟수가 1씩 차감됩니다.\\n  · 필요한 소환 횟수가 0회가 될 경우 해당 픽업 소환의 픽업 소환물이 확정적으로 출현합니다.\\n  · 소환으로 픽업 소환물이 출현한 경우, 픽업 확정까지의 필요한 소환 횟수 200회로 초기화됩니다.\\n \\n  \u203B 주의 사항\\n  · 출현 확률은 각 소환의 '확률 정보 표시' 목록을 확인해 주시기 바랍니다.\\n  · 본 소환의 픽업 포인트는 다른 소환의 픽업 포인트와 공유되지 않으며, 픽업 기간이 종료되면 이월되지 않고 사라집니다.\\n  · 각각의 출현 확률은 소수점 8번째 자리에서 버림하여 표시되므로 합계치가 100%가 되지 않을 수도 있습니다.\\n  · 본 소환에서는 중복되는 버디 혹은 서포터, 스킬카드가 출현할 가능성이 있습니다.\\n  · 통신 상태에 따라서는 소환의 연출이 건너뛰어지거나 정상적으로 표시되지 않을 수 있지만, 소환이 완료된 상태이므로 보유 상황을 확인해 주십시오.\\n  · 애니메이션 재생 시에 앱이 강제 종료되는 경우, 실행 중인 다른 앱을 종료한 후 다시 시도해주세요.\\n  · 본 소환 대상의 버디는 추후 재등장할 수 있습니다.\\n  · 개최 기간 및 내용은 예고 없이 변경될 수 있습니다.\\n  · 일부 디지몬은 관련 컨텐츠가 해금된 이후에 사용 가능합니다.\\n \\n 앞으로도 '디지몬 UP'에 많은 성원 부탁드립니다.\"}]}},{\"_noticeId\":\"379b92f6-fb33-4701-b2ff-8f9f5e50ec3d\",\"_type\":2,\"_contents\":{\"_list\":[{\"_languageType\":7,\"_title\":\"[Campaña] ¡Inicia la campaña de lanzamiento!\",\"_message\":\"Gracias por jugar DIGIMON UP.\\nSomos el equipo de administración.\\n\\nA partir de 15/07/2026 16:00 (UTC+9), hemos dado inicio a la campaña de lanzamiento.\\n\\n[Periodo de la campaña: 15/07/2026 16:00 (UTC+9) ~ 05/08/2026 14:59 (UTC+9)]\\n\\n■ Evento de minijuego\\nEl minijuego de esta ocasión es Combinación Digimon.\\nPara completar el juego, debes emparejar dos imágenes iguales de cada Digimon dentro del tiempo límite.\\nEl minijuego consta de varias etapas, y la dificultad aumenta a medida que avanzas.\\nPuedes jugar desde la sección \\\"Promociones\\\" de la pantalla de inicio.\\n\\n■ Recompensas exclusivas del minijuego\\nJuega al minijuego y completa las misiones del evento para obtener diversas recompensas.\\nLas misiones del evento incluyen misiones diarias y misiones de temporada.\\nLas misiones diarias se reinician todos los días a las 15:00 (UTC+9).\\nLas misiones de temporada solo se pueden completar una vez durante el periodo del evento.\\n\\n\u203BNotas importantes\\n・El periodo de duración y el contenido de esta campaña están sujetos a cambios sin previo aviso.\\n・Es posible que esta campaña vuelva a realizarse en el futuro.\\n・Una vez finalizado el periodo de la campaña, no se podrán completar las misiones del evento.\\n・Recoge las recompensas de las misiones completadas durante el periodo de la campaña.\\n・Algunas recompensas estarán disponibles para su uso una vez que se desbloqueen los contenidos relacionados.\\n\\nEsperamos que sigas disfrutando de DIGIMON UP.\"},{\"_languageType\":4,\"_title\":\"[이벤트] 출시 기념 이벤트 개최!\",\"_message\":\"07/15 16:00에 출시 기념 이벤트가 시작되었습니다.\\n\\n[개최 기간 : 2026/07/15 16:00 ~ 2026/08/05 14:59]\\n\\n ■ 이벤트 미니 게임\\n 이번 이벤트의 미니 게임은  \u2018디지몬 그림 맞추기\u2019 입니다.\\n 제한된 시간 동안 같은 디지몬 그림을 2장씩 모두 맞추면 클리어됩니다.\\n 미니 게임은 여러 개의 스테이지로 구성되어 있으며, 스테이지가 높아질수록 난이도도 높아집니다.\\n 이벤트 미니 게임은 홈 화면의 '이벤트\u2019를 통해 즐길 수 있습니다.\\n \\n ■ 미니 게임 전용 보상\\n 미니 게임을 진행해서 이벤트 미션을 달성하면 다양한 보상을 획득할 수 있습니다.\\n 이벤트 미션에는 일일 미션과 시즌 미션이 있습니다.\\n 일일 미션은 매일 15:00에 리셋됩니다.\\n 시즌 미션은 이벤트 기간에 1번만 클리어할 수 있습니다.\\n \\n \u203B 주의 사항\\n ・개최 기간 및 내용은 예고 없이 변경될 수 있습니다.\\n ・본 이벤트는 추후 재등장할 수 있습니다.\\n ・이벤트 개최 기간이 지나면 이벤트 미션을 달성할 수 없습니다.\\n ・달성한 이벤트 미션 보상은 이벤트 기간 내에 수령해 주세요.\\n ・일부 보상은 관련 콘텐츠가 해금된 이후에 사용 가능합니다.\\n \\n 앞으로도  \u2018디지몬 UP'에 많은 성원 부탁드립니다.\\n\"},{\"_languageType\":5,\"_title\":\"[Campagne] Campagne de lancement du service !\",\"_message\":\"Nous vous remercions de jouer à notre jeu.\\n Nous sommes l'équipe de gestion de DIGIMON UP.\\n \\n Nous avons lancé une campagne de célébration de lancement du jeu le 15/07 à 16 h 00 (UTC +9).\\n \\n [Période de l'événement : du 15/07/2026 à 16 h 00 (UTC +9) au 05/08/2026 à 14 h 59 (UTC +9)]\\n \\n ■ Mini-jeu\\n Ce mini-jeu est intitulé « Digipaires ».\\n Vous devez trouver deux cartes identiques de chaque Digimon dans le temps imparti pour gagner.\\n Le mini-jeu se compose de plusieurs étapes dont la difficulté augmente progressivement.\\n Vous pouvez accéder à ce mini-jeu depuis le menu « Campagne » de l'écran principal.\\n \\n ■ Récompenses spécifiques du mini-jeu\\n Vous pouvez obtenir diverses récompenses en jouant au mini-jeu et en accomplissant les missions de l'événement.\\n Ces missions sont réparties en « missions quotidiennes » et en « missions saisonnières ».\\n Les missions quotidiennes sont réinitialisées tous les jours à 15 h 00 (UTC+9).\\n Les missions saisonnières ne peuvent être terminées qu'une fois pendant la durée de l'événement.\\n \\n * Remarques\\n - La période et le contenu de cette campagne peuvent être modifiés sans préavis.\\n - Cette campagne pourrait être à nouveau organisée à l'avenir.\\n - Il ne sera plus possible d'accomplir les missions de l'événement une fois sa période terminée.\\n - Vous devez récupérer les récompenses des missions de l'événement que vous aurez réussies au cours de la période de disponibilité de la campagne.\\n - Certaines récompenses pourront être utilisées après le déblocage du contenu correspondant.\\n \\n Nous espérons que vous continuerez de soutenir DIGIMON UP.\"},{\"_languageType\":3,\"_title\":\"【特別活動】開服紀念特別活動開跑！\",\"_message\":\"感謝您一直以來的支持與喜愛。\\n 這裡是《數碼寶貝 UP》營運團隊。\\n \\n 自07/15 16:00(UTC+9)起，已開始舉辦開服紀念特別活動。\\n \\n 〔舉辦期間：2026/07/15 16:00(UTC+9) ~ 2026/08/05 14:59(UTC+9)〕\\n \\n ■ 小遊戲活動\\n 本次的小遊戲為「數碼寶貝翻翻樂」。\\n 只要在限制時間內，將相同數碼寶貝圖案全部湊成兩張一對即可過關。\\n 小遊戲分成數個關卡，難易度會隨著關卡推進而提升。\\n 小遊戲可從主畫面的「特別活動」進行遊玩。\\n \\n ■ 小遊戲專用報酬\\n 遊玩小遊戲並達成活動任務，即可獲得各式各樣的報酬。\\n 活動任務分為「每日任務」與「賽季任務」。\\n 每日任務將於每日15:00(UTC+9)進行重置。\\n 賽季任務在活動期間內僅限達成一次。\\n \\n \u203B注意事項\\n \u2027本特別活動的舉辦期間與內容，有可能未經預告逕行變更。\\n \u2027本特別活動今後有可能再次推出。\\n \u2027活動結束後，將無法再達成活動任務。\\n \u2027請於特別活動期間內領取已達成的活動任務報酬。\\n \u2027部分報酬需在解鎖相關內容後方可使用。\\n \\n 今後還請繼續支持《數碼寶貝 UP》。\"},{\"_languageType\":6,\"_title\":\"[Aktion] Aktion zur Feier des Service-Starts!\",\"_message\":\"Vielen Dank, dass du unser Spiel spielst.\\n Hier ist das \u201EDIGIMON UP\u201C-Team.\\n \\n Seit dem 15.07. um 16:00 Uhr (UTC+9) läuft eine Aktion zur Feier des Service-Starts.\\n \\n [Zeitraum: 15.07.2026 um 16:00 Uhr (UTC+9) bis 05.08.2026 um 14:59 Uhr (UTC+9)]\\n \\n ■ Minispiel-Event\\n Bei diesem Minispiel handelt es sich um \u201EDigimon-Memory\u201C.\\n Finde innerhalb des Zeitlimits alle Kartenpaare mit demselben Digimon.\\n Minispiele bestehen aus mehreren Stages, und je weiter du kommst, desto höher wird der Schwierigkeitsgrad.\\n Minispiele können über \u201EAktion\u201C auf dem Startbildschirm gespielt werden.\\n \\n ■ Exklusive Minispiel-Belohnungen\\n \\n Wenn du Minispiele spielst und Event-Missionen abschließt, kannst du verschiedene Belohnungen erhalten.\\n Es gibt zwei Arten von Event-Missionen \u2013 \u201ETägliche Missionen\u201C und \u201ESaison-Missionen\u201C.\\n Tägliche Missionen werden täglich um 15:00 Uhr (UTC+9) zurückgesetzt.\\n Saison-Missionen können während eines Event-Zeitraums nur einmal abgeschlossen werden.\\n \\n *Hinweise\\n ・Zeitraum und Inhalte dieser Aktion können ohne vorherige Ankündigung geändert werden.\\n ・Diese Aktion kann zu einem späteren Zeitpunkt erneut verfügbar sein.\\n ・Event-Missionen können nach Ende des Event-Zeitraums nicht mehr abgeschlossen werden.\\n ・Hole bitte Belohnungen für abgeschlossene Event-Missionen während des Aktionszeitraums ab.\\n ・Einige Belohnungen können erst nach Freischaltung entsprechender Inhalte genutzt werden.\\n \\n Wir danken dir für deine weitere Unterstützung von \u201EDIGIMON UP\u201C.\"},{\"_languageType\":2,\"_title\":\"【特别活动】开服纪念特别活动开跑！\",\"_message\":\"感谢您一直以来的支持与喜爱。\\n 这里是《数码宝贝 UP》运营团队。\\n \\n 自07/15 16:00(UTC+9)起，已开始举办开服纪念特别活动。\\n \\n 〔举办期间：2026/07/15 16:00(UTC+9) ~ 2026/08/05 14:59(UTC+9)〕\\n \\n ■ 小游戏活动\\n 本次的小游戏为\u201C数码宝贝翻翻乐\u201D。\\n 只要在限制时间内，将相同数码宝贝图案全部凑成两张一对即可过关。\\n 小游戏分成数个关卡，难易度会随着关卡推进而提升。\\n 小游戏可从主画面的\u201C特别活动\u201D进行游玩。\\n \\n ■ 小游戏专用报酬\\n 游玩小游戏并达成活动任务，即可获得各式各样的报酬。\\n 活动任务分为\u201C每日任务\u201D与\u201C赛季任务\u201D。\\n 每日任务将于每日15:00(UTC+9)进行重置。\\n 赛季任务在活动期间内仅限达成一次。\\n \\n \u203B注意事项\\n ·本特别活动的举办期间与内容，有可能未经预告径行变更。\\n ·本特别活动今后有可能再次推出。\\n ·活动结束后，将无法达成活动任务。\\n ·请于特别活动期间内，领取已达成的活动任务报酬。\\n ·部分报酬需在解锁相关内容后方可使用。\\n \\n 今后还请继续支持《数码宝贝 UP》。\"},{\"_languageType\":0,\"_title\":\"[Campaign] Launch Celebration Campaign Now On!\",\"_message\":\"Our launch celebration campaign is now live as of 07/15 16:00 (UTC +9)!\\n\\n[Event Period]: 07/15/2026 16:00 (UTC +9) - 08/05/2026 14:59(UTC+9)\\n\\n■ Minigame Event\\nThis event features the minigame \\\"Digimon Matching\\\"!\\nMatch all pairs of identical Digimon images before time runs out.\\nThe difficulty will increase as you clear each stage.\\nYou can access the minigame via \\\"Campaigns\\\" on the home screen.\\n\\n■ Minigame-Exclusive Rewards\\nPlay minigames and complete event missions to earn a wide range of exciting rewards!\\nThere are two types of event missions: Daily Missions and Seasonal Missions.\\nDaily Missions reset daily at 15:00 pm (UTC +9).\\nSeasonal Missions may only be completed once during the event period.\\n\\nNote:\\n* Event periods and campaign details are subject to change without notice.\\n* This campaign may be held again in the future.\\n* Event missions cannot be completed after the event period has ended.\\n* Please claim Event Mission Rewards before the campaign period ends.\\n* Some rewards may only be used after unlocking certain content.\\n\\nWe hope you continue to enjoy DIGIMON UP!\"},{\"_languageType\":8,\"_title\":\"[Campanha] Campanha de comemoração do lançamento!\",\"_message\":\"Obrigado por jogar nosso aplicativo.\\nAqui é a Equipe de Administração do DIGIMON UP.\\n\\nÀs 16:00 de 15/07 (UTC+9), iniciamos a campanha de comemoração do lançamento.\\n\\n[Período: 15/07/2026 16:00 (UTC+9) ~ 05/08/2026 14:59 (UTC+9)]\\n\\n■ Minijogo de evento\\nDesta vez, o minijogo é \\\"Combinar Digimon\\\".\\nPara completar o jogo, você precisa encontrar pares de Digimon iguais dentro do tempo-limite.\\nO minijogo tem vários estágios com dificuldade crescente.\\nExperimente-o em \\\"Campanhas\\\" na tela inicial.\\n\\n■ Recompensas exclusivas do minijogo\\nAo completar as missões do evento, você poderá ganhar várias recompensas.\\nAs missões do evento são compostas por \\\"missões diárias\\\" e \\\"missões sazonais\\\".\\nAs missões diárias são reiniciadas todos os dias às 15:00 (UTC+9).\\nAs missões sazonais só podem ser concluídas uma vez durante o evento.\\n\\n* Avisos\\n・ O período e os detalhes desta campanha podem ser alterados sem aviso prévio.\\n・ Não é possível concluir as missões do evento depois que a campanha terminar.\\n・ É necessário resgatar as recompensas obtidas nas missões do evento durante o período da campanha.\\n・ Algumas recompensas só podem ser utilizadas após liberar determinados conteúdos.\\n\\nEsperamos que você continue se divertindo com DIGIMON UP.\"},{\"_languageType\":1,\"_title\":\"【キャンペーン】サービス開始記念キャンペーン開催！\",\"_message\":\"07/15 16:00より、リリース記念キャンペーンを開始いたしました。\\n \\n [開催期間：2026/07/15 16:00 ~ 2026/08/05 14:59]\\n \\n ■ ミニゲームイベント\\n 今回のミニゲームは「デジモン合わせ」です。\\n 制限時間内に、同じデジモンの絵柄を2枚ずつすべて揃えるとクリアとなります。\\n ミニゲームは複数のステージで構成されており、ステージが進むほど難易度が上昇します。\\n ミニゲームは、ホーム画面の「キャンペーン」からプレイできます。\\n \\n ■ ミニゲーム専用報酬\\n ミニゲームをプレイして、イベントミッションを達成すると様々な報酬を獲得できます。\\n イベントミッションには、「デイリーミッション」と「シーズンミッション」があります。\\n デイリーミッションは毎日15:00にリセットされます。\\n シーズンミッションは、イベント期間中に1回のみ達成可能です。\\n \\n \u203B注意事項\\n ・本キャンペーンの開催期間および内容は、予告なく変更する場合があります。\\n ・本キャンペーンは、今後再登場する場合があります。\\n ・開催期間終了後、イベントミッションを達成することはできません。\\n ・達成したイベントミッションの報酬は、キャンペーン期間中にお受け取りください。\\n ・一部報酬は、関連コンテンツの解放後にご使用いただけます。\\n \\n 今後とも「デジモンUP」をよろしくお願いいたします。\"}]}},{\"_noticeId\":\"4cbe7c86-9620-449b-8728-d2b6657f73fd\",\"_type\":2,\"_contents\":{\"_list\":[{\"_languageType\":4,\"_title\":\"출시 기념 배틀 패스 포인트 2배!\",\"_message\":\" 07/15 16:00에 출시 기념으로 배틀 패스 포인트 획득 2배 보너스 이벤트가 개최되었습니다. \\n \\n [개최 기간: 2026/07/15 16:00 ~ 2026/07/31 14:59] \\n \\n ■ 2배 보너스 적용 배틀 패스 종류 \\n ・디지털 부스트 패스 \\n ・홀로그램 패스 \\n ・스킬 카드 패스 \\n ・서포터 패스 \\n \\n \u203B 주의 사항 \\n ・개최 기간 및 내용은 예고 없이 변경될 수 있습니다. \\n ・일부 보상은 관련 콘텐츠가 해금된 이후에 사용 가능합니다. \\n \\n 앞으로도 '디지몬 UP'에 많은 성원 부탁드립니다.\"},{\"_languageType\":1,\"_title\":\"「バトルパス獲得ポイント2倍ボーナスイベント」開催！\",\"_message\":\" 07/15 16:00より、サービス開始を記念して「バトルパスポイント獲得2倍ボーナス」イベントを開催いたしました。\\n \\n [開催期間：2026/07/15 16:00 ~ 2026/07/31 14:59]\\n \\n ■ 2倍ボーナス適用対象のバトルパス\\n ・デジタルブーストパス\\n ・ホログラムパス\\n ・スキルカードパス\\n ・サポーターパス\\n \\n \u203B 注意事項\\n ・本イベントの開催期間および内容は、予告なく変更する場合があります。\\n ・一部報酬は、関連コンテンツの解放後にご使用いただけます。\\n \\n 今後とも「デジモンUP」をよろしくお願いいたします。\"},{\"_languageType\":8,\"_title\":\"Para comemorar o lançamento do serviço, ganhe o dobro de pontos no Passe de Batalha!\",\"_message\":\"Obrigado por jogar nosso aplicativo.\\n Aqui é a Equipe de Administração do DIGIMON UP.\\n \\n Em 15/07 às 16:00 (UTC+9), foi realizado um evento com bônus de 2x na obtenção de pontos do Passe de Batalha para comemorar o lançamento do serviço.\\n \\n [Período: 15/07/2026 16:00 (UTC+9) ~ 31/07/2026 14:59 (UTC+9)]\\n \\n ■ Tipos de Passe de Batalha com bônus de 2x\\n ・Passe de Reforço Digital\\n ・Passe de Holograma\\n ・Passe de Carta de Habilidade\\n ・Passe de Auxiliar\\n \\n * Avisos\\n ・ O período e os detalhes desta campanha podem ser alterados sem aviso prévio.\\n ・ Algumas recompensas só podem ser utilizadas após liberar determinados conteúdos.\\n \\n Esperamos que você continue se divertindo com DIGIMON UP.\"},{\"_languageType\":0,\"_title\":\"Double Battle Pass Points to Celebrate the Service Launch!\",\"_message\":\"On 07/15 at 16:00 (UTC+9), a double Battle Pass point bonus event was held to celebrate the service launch.\\n \\n [Event Period]: 07/15/2026 16:00 (UTC +9) - 07/31/2026 14:59 (UTC +9)\\n \\n ■ Battle Pass Types Eligible for the 2x Bonus\\n ・Digital Boost Pass\\n ・Hologram Pass\\n ・Skill Card Pass\\n ・Support Pass\\n \\n Note:\\n * Event periods and campaign details are subject to change without notice.\\n * Some rewards may only be used after unlocking certain content.\\n \\n We hope you continue to enjoy DIGIMON UP!\"},{\"_languageType\":5,\"_title\":\"Pour fêter le lancement du service, doublez vos points de Battle Pass !\",\"_message\":\"Nous vous remercions de jouer à notre jeu.\\n Nous sommes l'équipe de gestion de DIGIMON UP.\\n \\n Le 15/07 à 16:00 (UTC+9), un événement offrant un bonus de 2x sur les points du Battle Pass a été organisé pour célébrer le lancement du service.\\n \\n [Période de l'événement : du 15/07/2026 à 16 h 00 (UTC +9) au 31/07/2026 à 14 h 59 (UTC +9)]\\n \\n ■ Types de Battle Pass bénéficiant d'un bonus x2\\n ・Passe boost numérique\\n ・Passe hologramme\\n ・Passe cartes de capacité\\n ・Passe soutiens\\n \\n * Remarques\\n - La période et le contenu de cette campagne peuvent être modifiés sans préavis.\\n - Certaines récompenses pourront être utilisées après le déblocage du contenu correspondant.\\n \\n Nous espérons que vous continuerez de soutenir DIGIMON UP.\"},{\"_languageType\":7,\"_title\":\"¡El doble de puntos del pase de batalla para celebrar el lanzamiento del servicio!\",\"_message\":\"Gracias por jugar DIGIMON UP.\\n Somos el equipo de administración.\\n \\n El día 15/07 a las 16:00 (UTC+9) se celebró un evento con una bonificación del doble de puntos del pase de batalla para conmemorar el lanzamiento del servicio.\\n \\n [Periodo de la campaña: 15/07/2026 16:00 (UTC+9) ~ 31/07/2026 14:59 (UTC+9)]\\n \\n ■ Tipos de pases de batalla con bonificación del doble\\n ・Pase de Digimejora\\n ・Pase de hologramas\\n ・Pase de cartas de habilidad\\n ・Pase de apoyo\\n \\n \u203BNotas importantes\\n ・El periodo de duración y el contenido de esta campaña están sujetos a cambios sin previo aviso.\\n ・Algunas recompensas estarán disponibles para su uso una vez que se desbloqueen los contenidos relacionados.\\n \\n Esperamos que sigas disfrutando de DIGIMON UP.\"},{\"_languageType\":3,\"_title\":\"為慶祝服務上線，戰鬥通行證點數雙倍！\",\"_message\":\"感謝您一直以來的支持與喜愛。\\n 這裡是《數碼寶貝 UP》營運團隊。\\n \\n 於07/15 16:00（UTC+9），為慶祝服務上線，舉辦了「戰鬥通行證點數獲取雙倍獎勵」活動。\\n \\n 〔舉辦期間：2026/07/15 16:00(UTC+9) ~ 2026/07/31 14:59(UTC+9)〕\\n \\n ■ 適用雙倍獎勵的戰鬥通行證類型\\n ・數碼強化通行證\\n ・全像投影通行證\\n ・技能卡片通行證\\n ・支援型通行證\\n \\n \u203B 注意事項\\n \u2027本特別活動的舉辦期間與內容，有可能未經預告逕行變更。\\n \u2027部分報酬需在解鎖相關內容後方可使用。\\n \\n 今後還請繼續支持《數碼寶貝 UP》。\"},{\"_languageType\":2,\"_title\":\"为庆祝服务上线，战斗通行证积分翻倍！\",\"_message\":\"感谢您一直以来的支持与喜爱。\\n 这里是《数码宝贝 UP》运营团队。\\n \\n 于07/15 16:00（UTC+9），为纪念服务上线，举办了\u201C战斗通行证积分双倍奖励\u201D活动。\\n \\n 〔举办期间：2026/07/15 16:00(UTC+9) ~ 2026/07/31 14:59(UTC+9)〕\\n \\n ■ 适用双倍奖励的战斗通行证类型\\n ・数码强化通行证\\n ・全息投影通行证\\n ・技能卡片通行证\\n ・支援型通行证\\n \\n \u203B 注意事项\\n ·本特别活动的举办期间与内容，有可能未经预告径行变更。\\n ·部分报酬需在解锁相关内容后方可使用。\\n \\n 今后还请继续支持《数码宝贝 UP》。\"},{\"_languageType\":6,\"_title\":\"Zur Feier des Service-Starts gibt es doppelte Battle-Pass-Punkte!\",\"_message\":\"Vielen Dank, dass du unser Spiel spielst.\\n Hier ist das \u201EDIGIMON UP\u201C-Team.\\n \\n Am 15/07 um 16:00 (UTC+9) fand anlässlich der Eröffnung des Dienstes ein Event statt, bei dem doppelte Battle-Pass-Punkte vergeben wurden.\\n \\n [Zeitraum: 15.07.2026 um 16:00 Uhr (UTC+9) bis 31.07.2026 um 14:59 Uhr (UTC+9)]\\n \\n ■ Battle-Pass-Varianten mit doppeltem Bonus\\n ・Digital-Boostpass\\n ・Hologramm-Pass\\n ・Fähigkeitskarten-Pass\\n ・Support-Pass\\n \\n * Hinweise\\n ・Zeitraum und Inhalte dieser Aktion können ohne vorherige Ankündigung geändert werden.\\n ・Einige Belohnungen können erst nach Freischaltung entsprechender Inhalte genutzt werden.\\n \\n Wir danken dir für deine weitere Unterstützung von \u201EDIGIMON UP\u201C.\"}]}},{\"_noticeId\":\"05c32e57-706d-48a0-9ae2-e63b808f5bed\",\"_type\":3,\"_contents\":{\"_list\":[{\"_languageType\":3,\"_title\":\"關於「戰鬥終端」與「D-1大獎賽」獎勵的公告\",\"_message\":\"感謝您一直以來的支持與喜愛。\\n這裡是《數碼寶貝 UP》營運團隊。\\n\\n茲就「戰鬥終端」與「D-1 大獎賽」獎勵的發放事宜，向各位說明如下。\\n\\n■ 戰鬥終端\\n・每日排行榜報酬 : 每日重置後，將透過郵件發放獎勵\\n・賽季排行榜報酬 : 每週重置後，將透過郵件發放獎勵至週三\\n\\n■ D-1大獎賽\\n・每週重置後，將透過郵件發放獎勵至週三\\n\\n今後還請繼續支持《數碼寶貝 UP》。\"},{\"_languageType\":1,\"_title\":\"バトルターミナル、D-1グランプリの報酬配布について\",\"_message\":\" バトルターミナルおよびD-1グランプリの報酬配布についてお知らせいたします。\\n \\n ■ バトルターミナル\\n ・デイリーランキング報酬：デイリーリセット後、メールにて配布\\n ・シーズンランキング報酬：ウィークリーリセット後、水曜日にメールにて配布\\n \\n ■ D-1グランプリ\\n ・ウィークリーリセット後、水曜日にメールにて配布\\n \\n 今後とも「デジモンUP」をよろしくお願いいたします。\"},{\"_languageType\":5,\"_title\":\"Informations concernant les récompenses du Grand Prix D-1 de Terminal de combat\",\"_message\":\"Nous vous remercions de jouer à notre jeu.\\nNous sommes l'équipe de gestion de DIGIMON UP.\\n\\nNous vous informons concernant la distribution des récompenses du Terminal de combat et du Grand Prix D-1.\\n\\n■ Terminal de combat\\n・Récompenses de classement quotidien : Les récompenses sont envoyées par courrier après la réinitialisation quotidienne\\n・Récompenses de classement de saison : Les récompenses sont envoyées par courrier à mercredi après la réinitialisation hebdomadaire\\n\\n■ Grand prix D-1\\n・Les récompenses sont envoyées par courrier à mercredi après la réinitialisation hebdomadaire\\n\\nNous espérons que vous continuerez de soutenir DIGIMON UP.\"},{\"_languageType\":4,\"_title\":\"배틀 터미널, D-1 그랑프리 보상에 대한 안내\",\"_message\":\" 배틀 터미널과 D-1 그랑프리 보상 지급에 대해 안내 드립니다. \\n \\n ■ 배틀 터미널 \\n ・일일 랭킹 보상 : 일일 리셋 이후 우편으로 보상 지급 \\n ・시즌 랭킹 보상 : 주간 리셋 이후 수요일에 우편으로 보상 지급 \\n \\n ■ D-1 그랑프리 \\n ・주간 리셋 이후 수요일에 우편으로 보상 지급 \\n \\n 앞으로도 '디지몬 UP'에 많은 성원 부탁드립니다.\"},{\"_languageType\":0,\"_title\":\"Notice Regarding Battle Terminal and D-1 Grand Prix Rewards\",\"_message\":\"We would like to provide information regarding the distribution of Battle Terminal and D-1 Grand Prix rewards.\\n  \\n  ■ Battle Terminal\\n  ・Daily Ranking Reward : Rewards will be sent via mail after the daily reset.\\n  ・Season Ranking Reward : Rewards will be sent via mail to Wednesday after the weekly reset.\\n  \\n  ■ D-1 Grand Prix\\n  ・Rewards will be sent via mail to Wednesday after the weekly reset.\\n  \\n  We hope you continue to enjoy DIGIMON UP!\"},{\"_languageType\":7,\"_title\":\"Información sobre las recompensas del Grand Prix D-1 de Terminal de combate\",\"_message\":\"Gracias por jugar DIGIMON UP.\\nSomos el equipo de administración.\\n\\nLes informamos sobre el reparto de recompensas de Terminal de combate y del Grand Prix D-1.\\n\\n■ Terminal de combate\\n・Recompensas diarias de clasificación : Las recompensas se envían por correo tras el reinicio diario.\\n・Recompensas de clasificación de temporada : Las recompensas se envían por correo a miércoles tras el reinicio semanal.\\n\\n■ Grand Prix D-1\\n・Las recompensas se envían por correo a miércoles tras el reinicio semanal.\\n\\nEsperamos que sigas disfrutando de DIGIMON UP.\"},{\"_languageType\":6,\"_title\":\"Informationen zu den Belohnungen für den Kampf-Terminal-D-1 Grand Prix\",\"_message\":\"Vielen Dank, dass du unser Spiel spielst.\\nHier ist das \u201EDIGIMON UP\u201C-Team.\\n\\nHiermit möchten wir Sie über die Auszahlung der Belohnungen für das Kampf-Terminal und den D-1 Grand Prix informieren.\\n\\n■ Kampf-Terminal\\n・Tägliche Ranglistenbelohnung : Auszahlung der Belohnung per Post nach dem täglichen Reset\\n・Saison-Ranglistenbelohnung : Auszahlung der Belohnung per Post an Mittwoch nach dem wöchentlichen Reset\\n\\n■ D-1 Grand Prix\\n・Auszahlung der Belohnung per Post an Mittwoch nach dem wöchentlichen Reset\\n\\nWir danken dir für deine weitere Unterstützung von \u201EDIGIMON UP\u201C.\"},{\"_languageType\":8,\"_title\":\"Informações sobre as recompensas do Terminal de Batalha e do Grand Prix D-1\",\"_message\":\"Obrigado por jogar nosso aplicativo.\\nAqui é a Equipe de Administração do DIGIMON UP.\\n\\nGostaríamos de informar sobre a distribuição das recompensas do Terminal de Batalha e do Grand Prix D-1.\\n\\n■ Terminal de Batalha\\n・Recompensa de ranking diário : Pagamento da recompensa por correio após a reinicialização diária\\n・Recompensa de ranking sazonal : A recompensa será enviada por correio para quarta-feira após a reinicialização semanal\\n\\n■ Grand Prix D-1\\n・A recompensa será enviada por correio para quarta-feira após a reinicialização semanal\\n\\nEsperamos que você continue se divertindo com DIGIMON UP.\"},{\"_languageType\":2,\"_title\":\"关于\u201C战斗终端\u201D和\u201CD-1大奖赛\u201D奖励的通知\",\"_message\":\"感谢您一直以来的支持与喜爱。\\n这里是《数码宝贝 UP》运营团队。\\n\\n现就\u201C战斗终端\u201D和\u201CD-1大奖赛\u201D的奖励发放事宜进行通知。\\n\\n■ 战斗终端\\n・每日排行榜报酬 : 每日重置后通过邮件发放奖励\\n・赛季排行榜报酬 : 每周重置后通过邮件向周三发放奖励\\n\\n■ D-1大奖赛\\n・每周重置后通过邮件向周三发放奖励\\n\\n今后还请继续支持《数码宝贝 UP》。\"}]}},{\"_noticeId\":\"fbc10e3f-4de2-468a-8ebe-97113ca05abf\",\"_type\":3,\"_contents\":{\"_list\":[{\"_languageType\":6,\"_title\":\"Mitteilung bezüglich des Aussehens von Ausrüstungs-Items\",\"_message\":\"Vielen Dank, dass du unser Spiel spielst.\\nHier ist das \u201EDIGIMON UP\u201C-Team.\\n\\nWir möchten dich über das Aussehen einiger Items informieren.\\n\\n- Bei einigen Ausrüstungs-Items der Kategorie \u201EHaarschmuck\u201C werden beim Einstellen des Aussehens die Haare und Accessoires nicht angezeigt.\\n\\n■ Liste der betroffenen Items\\n・ Agumon-Pyjama (Kopf)\\n・ Gatomon-Pyjama (Kopf)\\n・ Patamon-Pyjama (Kopf)\\n・ Brauner Sonnenhut\\n・ Schwarzer Zylinder\\n・ Blau-grüne Baskenmütze\\n・ Grüne Militärkappe\\n・ Schwarzer Sonnenhut\\n・ Lila Zylinder\\n・ Gelbe Baskenmütze\\n・ Lila Militärkappe\\n・ Weißer Sonnenhut\\n・ Roter Zylinder\\n・ Rote Baskenmütze\\n・ Graue Militärkappe\\n・ Schwarze Matrosenmütze\\n・ Weiß-grüne Strickmütze\\n・ Braune Matrosenmütze\\n・ Blau-orangene Strickmütze\\n\\nWir danken dir für deine weitere Unterstützung von \u201EDIGIMON UP\u201C.\"},{\"_languageType\":4,\"_title\":\"아이템 외형에 대한 안내\",\"_message\":\" 일부 아이템 외형에 대해 안내 드립니다.\\n ・헤어장식 장비 아이템 중 일부는 헤어, 액세서리 장비 아이템 표현을 하지 않습니다.\\n  \\n  [해당하는 아이템 목록]\\n  ・ 아구몬 잠옷(머리)\\n  ・ 가트몬 잠옷(머리)\\n  ・ 파닥몬 잠옷(머리)\\n  ・ 브라운 썬햇\\n  ・ 블랙 실크햇\\n  ・ 블루 그린 베레모\\n  ・ 그린 밀리터리 캡\\n  ・ 블랙 썬햇\\n  ・ 퍼플 실크햇\\n  ・ 옐로우 베레모\\n  ・ 퍼플 밀리터리 캡\\n  ・ 화이트 썬햇\\n  ・ 레드 실크햇\\n  ・ 레드 베레모\\n  ・ 그레이 밀리터리 캡\\n  ・ 블랙 세일러 캡\\n  ・ 화이트 & 그린 비니\\n  ・ 브라운 세일러 캡\\n  ・ 블루 & 오렌지 비니\\n \\n  앞으로도 '디지몬 UP'에 많은 성원 부탁드립니다.\"},{\"_languageType\":0,\"_title\":\"Notice Regarding Gear Appearances\",\"_message\":\"We would like to share some information regarding certain items' appearance.\\n  \\n  ・When setting your appearance, certain Head Ornaments may obscure hair and accessories.\\n  \\n  ■Applicable Gear\\n  ・ Agumon Pajamas (Head)\\n  ・ Gatomon Pajamas (Head)\\n  ・ Patamon Pajamas (Head)\\n  ・ Brown Sun Hat\\n  ・ Black Top Hat\\n  ・ Teal Beret\\n  ・ Green Military Cap\\n  ・ Black Sun Hat\\n  ・ Purple Top Hat\\n  ・ Yellow Beret\\n  ・ Purple Military Cap\\n  ・ White Sun Hat\\n  ・ Red Top Hat\\n  ・ Red Beret\\n  ・ Gray Military Cap\\n  ・ Black Sailor Hat\\n  ・ White & Green Beanie\\n  ・ Brown Sailor Hat\\n  ・ Blue & Orange Beanie\\n \\n We hope you continue to enjoy DIGIMON UP!\"},{\"_languageType\":1,\"_title\":\"装備アイテム外見に関するお知らせ\",\"_message\":\" 一部アイテムの外見についてお知らせにてご案内いたします。\\n ・「髪飾り」の装備アイテムの一部は、外見設定時に髪およびアクセサリーの表示を行わない仕様となっております。\\n\\n■ 該当アイテム一覧\\n ・アグモンパジャマ(頭)\\n ・テイルモンパジャマ(頭)\\n ・パタモンパジャマ(頭)\\n ・ブラウンサンハット\\n ・ブラックシルクハット\\n ・ブルーグリーンベレー帽\\n ・グリーンミリタリーキャップ\\n ・ブラックサンハット\\n ・パープルシルクハット\\n ・イエローベレー帽\\n ・パープルミリタリーキャップ\\n ・ホワイトサンハット\\n ・レッドシルクハット\\n ・レッドベレー帽\\n ・グレーミリタリーキャップ\\n ・ブラックセーラーハット\\n ・ホワイト＆グリーンニット帽\\n ・ブラウンセーラーハット\\n ・ブルー＆オレンジニット帽\\n\\n 今後とも「デジモンUP」をよろしくお願いいたします。\"},{\"_languageType\":5,\"_title\":\"Annonce concernant l'apparence des objets équipés\",\"_message\":\"Nous vous remercions de jouer à notre jeu.\\nNous sommes l'équipe de gestion de DIGIMON UP.\\n\\nNous souhaitons vous informer au sujet de l'apparence de certains objets.\\n\\n・Lors du choix de l'apparence, certains Accessoires pour cheveux peuvent masquer les cheveux et les accessoires.\\n\\n■ Liste des objets concernés\\n・ Pyjama Agumon (tête)\\n・ Pyjama Gatomon (tête)\\n・ Pyjama Patamon (tête)\\n・ Chapeau de soleil marron\\n・ Haut-de-forme noir\\n・ Béret bleu-vert\\n・ Casquette militaire verte\\n・ Chapeau de soleil noir\\n・ Haut-de-forme violet\\n・ Béret jaune\\n・ Casquette militaire violette\\n・ Chapeau de soleil blanc\\n・ Haut-de-forme rouge\\n・ Béret rouge\\n・ Casquette militaire grise\\n・ Chapeau de marin noir\\n・ Bonnet blanc et vert\\n・ Chapeau de marin marron\\n・ Bonnet bleu et orange\\n\\nNous espérons que vous continuerez de soutenir DIGIMON UP.\"},{\"_languageType\":8,\"_title\":\"Aviso sobre a aparência dos itens de equipamento\",\"_message\":\"Obrigado por jogar nosso aplicativo.\\nAqui é a Equipe de Administração do DIGIMON UP.\\n\\nSegue um anúncio sobre a aparência de alguns itens.\\n・A aparência de alguns itens de equipamento da categoria \\\"Enfeite de Cabelo\\\" ocultam a exibição do cabelo e dos acessórios nas configurações de aparência.\\n\\n■ Lista de itens afetados\\n・ Pijama do Agumon (cabeça)\\n・ Pijama do Gatomon (cabeça)\\n・ Pijama do Patamon (cabeça)\\n・ Chapéu de praia marrom\\n・ Cartola preta\\n・ Boina esverdeada\\n・ Quepe verde\\n・ Chapéu de praia preto\\n・ Cartola roxa\\n・ Boina amarela\\n・ Quepe roxo\\n・ Chapéu de praia branco\\n・ Cartola vermelha\\n・ Boina vermelha\\n・ Quepe cinza\\n・ Chapéu de marinheiro preto\\n・ Gorro de lã verde e branco\\n・ Chapéu de marinheiro marrom\\n・ Gorro de lã azul e laranja\\n\\nEsperamos que você continue se divertindo com DIGIMON UP.\"},{\"_languageType\":3,\"_title\":\"關於裝備道具外觀的通知\",\"_message\":\"感謝您一直以來的支持與喜愛。\\n這裡是《數碼寶貝 UP》營運團隊。\\n\\n關於部分道具的外觀，我們將於通知進行說明。\\n・部分「髮飾」的裝備道具，於外觀設定時不會顯示頭髮以及飾品。\\n\\n■符合的道具一覽\\n・ 亞古獸睡衣（頭）\\n・ 迪路獸睡衣（頭）\\n・ 巴達獸睡衣（頭）\\n・ 棕色寬邊遮陽帽\\n・ 黑色高頂禮帽\\n・ 藍綠貝雷帽\\n・ 綠色軍帽\\n・ 黑色寬邊遮陽帽\\n・ 紫色高頂禮帽\\n・ 黃色貝雷帽\\n・ 紫色軍帽\\n・ 白色寬邊遮陽帽\\n・ 紅色高頂禮帽\\n・ 紅色貝雷帽\\n・ 灰色軍帽\\n・ 黑色水手帽\\n・ 白色＆綠色針織帽\\n・ 棕色水手帽\\n・ 藍色＆橘色針織帽\\n\\n今後還請繼續支持《數碼寶貝 UP》。\"},{\"_languageType\":7,\"_title\":\"Aviso sobre la apariencia de los objetos de equipo\",\"_message\":\"Gracias por jugar DIGIMON UP.\\nSomos el equipo de administración.\\n\\nA continuación, les informamos sobre la apariencia de ciertos objetos.\\n・Algunos objetos de equipamiento de la categoría \\\"Adornos para el pelo\\\" están configurados para no mostrar el pelo ni los accesorios en los ajustes de apariencia.\\n\\n■ Lista de objetos afectados\\n・ Pijama de Agumon (cabeza)\\n・ Pijama de Gatomon (cabeza)\\n・ Pijama de Patamon (cabeza)\\n・ Sombrero playero marrón\\n・ Sombrero de copa negro\\n・ Boina azul verdosa\\n・ Gorra militar verde\\n・ Sombrero playero negro\\n・ Sombrero de copa morado\\n・ Boina amarilla\\n・ Gorra militar morada\\n・ Sombrero playero blanco\\n・ Sombrero de copa rojo\\n・ Boina roja\\n・ Gorra militar gris\\n・ Gorro de marinero negro\\n・ Gorro de lana blanco y verde\\n・ Gorro de marinero marrón\\n・ Gorro de lana azul y naranja\\n\\nEsperamos que sigan disfrutando de DIGIMON UP.\"},{\"_languageType\":2,\"_title\":\"装备道具外观相关通知\",\"_message\":\"感谢您一直以来的支持与喜爱。\\n这里是《数码宝贝 UP》运营团队。\\n\\n关于部分道具的外观，我们将在本通知中向各位玩家进行说明。\\n・部分\u201C发饰\u201D类装备道具在外观设定时，将不会显示头发及饰品。\\n\\n■符合条件的道具一览\\n・ 亚古兽睡衣（头）\\n・ 迪路兽睡衣（头）\\n・ 巴达兽睡衣（头）\\n・ 棕色宽边遮阳帽\\n・ 黑色高顶礼帽\\n・ 蓝绿贝雷帽\\n・ 绿色军帽\\n・ 黑色宽边遮阳帽\\n・ 紫色高顶礼帽\\n・ 黄色贝雷帽\\n・ 紫色军帽\\n・ 白色宽边遮阳帽\\n・ 红色高顶礼帽\\n・ 红色贝雷帽\\n・ 灰色军帽\\n・ 黑色水手帽\\n・ 白色＆绿色针织帽\\n・ 棕色水手帽\\n・ 蓝色＆橘色针织帽\\n\\n今后还请继续支持《数码宝贝 UP》。\"}]}},{\"_noticeId\":\"f22dffa5-7fe7-448e-b75a-c2d0191e3a44\",\"_type\":3,\"_contents\":{\"_list\":[{\"_languageType\":1,\"_title\":\"【お知らせ】スキルカード等の余剰素材について\",\"_message\":\" スキルカードやサポーターデジモンなどを最大レベルまで強化した際に余った素材につきましては、今後活用できるようなアップデート対応を予定しております。\\n 対象コンテンツは以下のとおりです。\\n ・スキルカード\\n ・サポーターデジモン\\n ・バディ\\n ・SPサポーター\\n ・異次元BOX装飾\\n \\n 今後とも「デジモンUP」をよろしくお願いいたします。\"},{\"_languageType\":0,\"_title\":\"[Notice] About Surplus Materials (Skill Cards, etc.)\",\"_message\":\"We are planning an update to enable the use of surplus materials after Skill Cards, Support Digimon, and other items have already been enhanced to their maximum level.\\n This includes the following:\\n \u2022 Skill Cards\\n \u2022 Support Digimon\\n \u2022 Buddies\\n \u2022 SP Support\\n \u2022 DD Box Decor\\n \\n We hope you continue to enjoy DIGIMON UP!\"},{\"_languageType\":8,\"_title\":\"[Anúncio] Sobre materiais excedentes\",\"_message\":\"Obrigado por jogar nosso aplicativo.\\nAqui é a Equipe de Administração do DIGIMON UP.\\n\\nEstamos planejando uma atualização que permitirá aos jogadores utilizar os materiais excedentes do aprimoramento de Cartas de Habilidade e Digimon Auxiliares, entre outros, até o nível máximo.\\nOs conteúdos incluídos são os seguintes:\\n・ Cartas de Habilidade\\n・ Digimon Auxiliares\\n・ Amigos\\n・ Auxiliares SP\\n・ Ornamentos da Caixa de Dimensão Paralela\\n\\nEsperamos que você continue se divertindo com DIGIMON UP.\"},{\"_languageType\":3,\"_title\":\"【通知】關於技能卡片等剩餘素材\",\"_message\":\"感謝您一直以來的支持與喜愛。\\n這裡是《數碼寶貝 UP》營運團隊。\\n\\n將技能卡片、支援型數碼寶貝等強化至最高等級後剩餘的素材，預計將於未來的更新中追加後續的活用方式。\\n適用內容如下：\\n\u2027技能卡片\\n\u2027支援型數碼寶貝\\n\u2027搭檔\\n\u2027SP支援型\\n\u2027異次元BOX裝飾\\n\\n今後還請繼續支持《數碼寶貝 UP》。\"},{\"_languageType\":5,\"_title\":\"[Annonce] Matériaux restants (cartes de capacité, etc.)\",\"_message\":\"Nous vous remercions de jouer à notre jeu.\\nNous sommes l'équipe de gestion de DIGIMON UP.\\n\\nNous prévoyons d'implémenter une mise à jour qui vous permettra d'utiliser les matériaux restants après avoir renforcé des cartes de capacité, des Digimon de soutien ou d'autres éléments jusqu'au niveau maximum.\\nVoici les contenus concernés :\\n- Cartes de capacité\\n- Digimon de soutien\\n- Caramades\\n- Soutiens SP\\n- Décorations de boîte dimension\\n\\nNous espérons que vous continuerez de soutenir DIGIMON UP.\"},{\"_languageType\":2,\"_title\":\"【通知】关于技能卡片等剩余素材\",\"_message\":\"感谢您一直以来的支持与喜爱。\\n这里是《数码宝贝 UP》运营团队。\\n\\n针对将技能卡片、支援型数码宝贝等强化至最高等级后剩余的素材，预计将在后续更新中推出相应的活用方案。\\n适用内容如下：\\n·技能卡片\\n·支援型数码宝贝\\n·搭档\\n·SP支援型\\n·异次元BOX装饰\\n\\n今后还请继续支持《数码宝贝 UP》。\"},{\"_languageType\":7,\"_title\":\"[Aviso] Sobre los materiales sobrantes\",\"_message\":\"Gracias por jugar DIGIMON UP.\\nSomos el equipo de administración.\\n\\nTenemos previsto implementar una actualización que permita aprovechar los materiales sobrantes al fortalecer al máximo las cartas de habilidades, los Digimon de apoyo y otros elementos. \\nLos contenidos afectados son los siguientes:\\n・Cartas de habilidad\\n・Digimon de apoyo\\n・Colegas\\n・Apoyo SP\\n・Adornos de caja dimensional\\n\\nEsperamos que sigas disfrutando de DIGIMON UP.\"},{\"_languageType\":6,\"_title\":\"[Mitteilung] Überschüssige Materialien\",\"_message\":\"Vielen Dank, dass du unser Spiel spielst.\\nHier ist das \u201EDIGIMON UP\u201C-Team.\\n\\nMaterialien, die nach dem Verstärken von Fähigkeitskarten, Support-Digimon usw. auf das maximale Level übrig bleiben, sollen künftig durch ein Update verwendet werden können.\\nFolgende Inhalte sind davon betroffen.\\n・Fähigkeitskarten\\n・Support-Digimon\\n・Kameraden\\n・SP-Support\\n・Dimensionsbox-Dekorationen\\n\\nWir danken dir für deine weitere Unterstützung von \u201EDIGIMON UP\u201C.\"},{\"_languageType\":4,\"_title\":\"[공지] 스킬 카드 등의 남은 재료에 대한 안내\",\"_message\":\"스킬 카드,서포터 등을 최대 레벨까지 강화하고 남은 재료는 추후 활용 가능하도록 업데이트 예정입니다.\\n적용될 콘텐츠는 다음과 같습니다.\\n・스킬 카드\\n・서포터 디지몬\\n・버디\\n・SP 서포터\\n・이차원 박스 장식\\n\\n앞으로도 '디지몬 UP'에 많은 성원 부탁드립니다.\\n\"}]}},{\"_noticeId\":\"6aed513b-2011-4d4a-8742-662d0d031e19\",\"_type\":3,\"_contents\":{\"_list\":[{\"_languageType\":1,\"_title\":\"【お知らせ】「異次元BOX」に関するコンテンツ説明\",\"_message\":\"「異次元BOX」の詳細コンテンツ説明についてお知らせにてご案内いたします。\\n \\n ■ 異次元BOXでのバディ接続について\\n 異次元BOXでさまざまな報酬を獲得するには、\\n 異次元BOX内に配置されたデバイスに所持しているバディを接続する必要があります。\\n \u203B1つの異次元BOXにつき、1台のデバイスにのみ所持するバディを接続することが可能です。\\n \\n ■ オーバーロードについて\\n 異次元BOXでバトルを行うたびに上昇する「オーバーロード」値に応じて、以下のデバフ効果が発生します。\\n \\n ▶ 攻撃側のオーバーロード（A.OVR）\\n ・オーバーロード15%以上：基本攻撃力、基本防御力、基本体力が10%減少\\n ・オーバーロード30%以上：基本攻撃力、基本防御力、基本体力が30%減少\\n ・オーバーロード45%以上：基本攻撃力、基本防御力、基本体力が70%減少\\n ・オーバーロード60%以上：基本攻撃力、基本防御力、基本体力が80%減少\\n ・オーバーロード90%以上：基本攻撃力、基本防御力、基本体力が99%減少\\n \\n ▶ 守備側のオーバーロード（D.OVR）\\n ・オーバーロード15%以上：基本攻撃力、基本防御力が15%減少\\n ・オーバーロード30%以上：基本攻撃力、基本防御力が35%減少\\n ・オーバーロード45%以上：基本攻撃力、基本防御力が75%減少\\n ・オーバーロード60%以上：基本攻撃力、基本防御力が85%減少\\n ・オーバーロード90%以上：基本攻撃力、基本防御力が99%減少\\n \\n \u203B「オーバーロード」値は時間経過とともに徐々に減少いたします。\\n \\n 今後とも「デジモンUP」をよろしくお願いいたします。\"},{\"_languageType\":7,\"_title\":\"[Aviso] Contenido de la Caja dimensional\",\"_message\":\"Gracias por jugar DIGIMON UP.\\nSomos el equipo de administración.\\n\\nInformamos detalles sobre la Caja Dimensional.\\n\\n■ Sobre la conexión de colegas:\\nPara obtener recompensas en la Caja Dimensional, debes conectar tus colegas a los dispositivos ubicados allí.\\nSolo puedes conectar un colega por dispositivo.\\n\\n■ Sobre la sobrecarga:\\nSegún el valor de la sobrecarga que aumente cada vez que luches en la Caja Dimensional, se producirán los siguientes efectos negativos:\\n\\n▶ Sobrecarga del atacante (A.SBC)\\n・Sobrecarga de 15% o más: el ataque básico, la defensa básica y la salud básica se reducen en un 10%\\n・Sobrecarga de 30% o más: el ataque básico, la defensa básica y la salud básica se reducen en un 30%\\n・Sobrecarga de 45% o más: la fuerza de ataque básica, la defensa básica y la salud básica se reducen en un 70%\\n・Sobrecarga de 60% o más: la fuerza de ataque básica, la defensa básica y la salud básica se reducen en un 80%\\n・Sobrecarga de 90% o más: la fuerza de ataque básica, la defensa básica y la salud básica se reducen en un 99%\\n\\n▶ Sobrecarga del defensor (D.SBC)\\n・Sobrecarga de 15% o más: el ataque básico y la defensa básica se reducen en un 15%\\n・Sobrecarga de 30% o más: el ataque básico y la defensa básica se reducen en un 35%\\n・Sobrecarga de 45% o más: la fuerza de ataque básica y la defensa básica se reducen en un 75%\\n・Sobrecarga de 60% o más: la fuerza de ataque básica y la defensa básica se reducen en un 85%\\n・Sobrecarga de 90% o más: la fuerza de ataque básica y la defensa básica se reducen en un 99%\\n\\n\u203BEl valor de la sobrecarga disminuye gradualmente con el paso del tiempo.\\n\\nEsperamos que sigas disfrutando de DIGIMON UP.\"},{\"_languageType\":2,\"_title\":\"【通知】关于\u201C异次元BOX\u201D的内容说明\",\"_message\":\"感谢您一直以来的支持与喜爱。\\n这里是《数码宝贝 UP》运营团队。\\n\\n现对\u201C异次元BOX\u201D的详细内容说明如下。\\n\\n■ 关于异次元BOX的搭档连线\\n若想在异次元BOX中获得各种报酬，\\n必须将持有的搭档与设置在异次元BOX内的装置进行连线。\\n\u203B每个异次元BOX仅限一台装置能与持有的搭档进行连线。\\n\\n■ 关于超载值\\n每当在异次元BOX中进行战斗时会提升\u201C超载值\u201D，将根据该数值触发以下减益效果。\\n\\n▶攻击方的超载值（A.OVR）\\n·超载值15%以上：基本攻击力、基本防御力、基本体力减少10%\\n·超载值30%以上：基本攻击力、基本防御力、基本体力减少30%\\n·超载值45%以上：基本攻击力、基本防御力、基本体力减少70%\\n·超载值60%以上：基本攻击力、基本防御力、基本体力减少80%\\n·超载值90%以上：基本攻击力、基本防御力、基本体力减少99%\\n\\n▶守备方的超载值（D.OVR）\\n·超载值15%以上：基本攻击力、基本防御力减少15%\\n·超载值30%以上：基本攻击力、基本防御力减少35%\\n·超载值45%以上：基本攻击力、基本防御力减少75%\\n·超载值60%以上：基本攻击力、基本防御力减少85%\\n·超载值90%以上：基本攻击力、基本防御力减少99%\\n\\n\u203B\u201C超载值\u201D会随着时间推进而逐渐减少。\\n\\n今后还请继续支持《数码宝贝 UP》。\"},{\"_languageType\":3,\"_title\":\"【通知】關於「異次元BOX」的內容說明\",\"_message\":\"感謝您一直以來的支持與喜愛。\\n這裡是《數碼寶貝 UP》營運團隊。\\n\\n在此針對「異次元BOX」的詳細內容進行說明。\\n\\n■ 關於異次元BOX的搭檔連線\\n若想在異次元BOX中獲得各種報酬，\\n必須將持有的搭檔與設置在異次元BOX內的裝置進行連線。\\n\u203B每個異次元BOX僅限一台裝置能與持有的搭檔進行連線。\\n\\n■ 關於超載值\\n每當在異次元BOX中進行戰鬥時會提升「超載值」，將根據該數值觸發以下減益效果。\\n\\n▶攻擊方的超載值（A.OVR）\\n\u2027超載值15%以上：基本攻擊力、基本防禦力、基本體力減少10%\\n\u2027超載值30%以上：基本攻擊力、基本防禦力、基本體力減少30%\\n\u2027超載值45%以上：基本攻擊力、基本防禦力、基本體力減少70%\\n\u2027超載值60%以上：基本攻擊力、基本防禦力、基本體力減少80%\\n\u2027超載值90%以上：基本攻擊力、基本防禦力、基本體力減少99%\\n\\n▶守備方的超載值（D.OVR）\\n\u2027超載值15%以上：基本攻擊力、基本防禦力減少15%\\n\u2027超載值30%以上：基本攻擊力、基本防禦力減少35%\\n\u2027超載值45%以上：基本攻擊力、基本防禦力減少75%\\n\u2027超載值60%以上：基本攻擊力、基本防禦力減少85%\\n\u2027超載值90%以上：基本攻擊力、基本防禦力減少99%\\n\\n\u203B「超載值」會隨著時間推進而逐漸減少。\\n\\n今後還請繼續支持《數碼寶貝 UP》。\"},{\"_languageType\":0,\"_title\":\"[Notice] About \\\"DD Box\\\" Contents\",\"_message\":\"Please refer below for detailed information about the DD Box.\\n \\n ■ Connecting a Buddy to a DD Box\\n To obtain various DD Box rewards, you must connect your Buddy to the device placed inside a DD Box.\\n * Each Buddy can only be connected to one device per DD Box.\\n \\n ■ Overload\\n The following debuff effects will be applied depending on the \\\"Overload\\\" value, which increases each time a DD Box battle is carried out.\\n \\n ▶ Attacker Overload (A. OVR)\\n \u2022 Overload 15% or higher: Basic ATK, Basic DEF, and Basic HP decrease by 10%\\n \u2022 Overload 30% or higher: Basic ATK, Basic DEF, and Basic HP decrease by 30%\\n \u2022 Overload 45% or higher: Basic ATK, Basic DEF, and Basic HP decrease by 70%\\n \u2022 Overload 60% or higher: Basic ATK, Basic DEF, and Basic HP decrease by 80%\\n \u2022 Overload 90% or higher: Basic ATK, Basic DEF, and Basic HP decrease by 99%\\n \\n ▶ Defender Overload (D. OVR)\\n \u2022 Overload 15% or higher: Basic ATK and Basic DEF decrease by 15%\\n \u2022 Overload 30% or higher: Basic ATK and Basic DEF decrease by 35%\\n \u2022 Overload 45% or higher: Basic ATK and Basic DEF decrease by 75%\\n \u2022 Overload 60% or higher: Basic ATK and Basic DEF decrease by 85%\\n \u2022 Overload 90% or higher: Basic ATK and Basic DEF decrease by 99%\\n \\n * Overload value will gradually decrease over time.\\n \\n We hope you continue to enjoy DIGIMON UP!\"},{\"_languageType\":6,\"_title\":\"[Mitteilung] Details zur \u201EDimensionsbox\u201C\",\"_message\":\"Vielen Dank, dass du unser Spiel spielst.\\nHier ist das \u201EDIGIMON UP\u201C-Team.\\n\\nWir informieren dich über die Details zur \u201EDimensionsbox\u201C.\\n\\n■ Verbinden von Kameraden in der Dimensionsbox\\nUm verschiedene Belohnungen in der Dimensionsbox zu erhalten, musst du deinen Kameraden mit einem in der Dimensionsbox platzierten Gerät verbinden.\\n*Pro Dimensionsbox kann dein Kamerad nur mit einem Gerät verbunden werden.\\n\\n■ Overload\\nMit jedem Kampf in der Dimensionsbox steigt der Overload-Wert an, und es treten folgende Debuffs auf.\\n\\n▶ Overload für die Angriffsseite (A.OVL)\\n・Bei 15 % Overload oder höher: Basis-Angriffskraft, Basis-Verteidigungskraft, Basis-TP werden um 10 % reduziert.\\n・Bei 30 % Overload oder höher: Basis-Angriffskraft, Basis-Verteidigungskraft, Basis-TP werden um 30 % reduziert.\\n・Bei 45 % Overload oder höher: Basis-Angriffskraft, Basis-Verteidigungskraft, Basis-TP werden um 70 % reduziert.\\n・Bei 60 % Overload oder höher: Basis-Angriffskraft, Basis-Verteidigungskraft, Basis-TP werden um 80 % reduziert.\\n・Bei 90 % Overload oder höher: Basis-Angriffskraft, Basis-Verteidigungskraft, Basis-TP werden um 99 % reduziert.\\n\\n▶ Overload für die Verteidigungsseite (V.OVL)\\n・Bei 15 % Overload oder höher: Basis-Angriffskraft, Basis-Verteidigungskraft werden um 15 % reduziert.\\n・Bei 30 % Overload oder höher: Basis-Angriffskraft, Basis-Verteidigungskraft werden um 35 % reduziert.\\n・Bei 45 % Overload oder höher: Basis-Angriffskraft, Basis-Verteidigungskraft werden um 75 % reduziert.\\n・Bei 60 % Overload oder höher: Basis-Angriffskraft, Basis-Verteidigungskraft werden um 85 % reduziert.\\n・Bei 90 % Overload oder höher: Basis-Angriffskraft, Basis-Verteidigungskraft werden um 99 % reduziert.\\n\\nDer Overload-Wert nimmt mit der Zeit allmählich ab.\\n\\nWir danken dir für deine weitere Unterstützung von \u201EDIGIMON UP\u201C.\"},{\"_languageType\":5,\"_title\":\"[Annonce] Description du contenu lié aux boîtes dimension\",\"_message\":\"Nous vous remercions de jouer à notre jeu.\\nNous sommes l'équipe de gestion de DIGIMON UP.\\n\\nVous trouverez dans cette annonce des détails relatifs au contenu des boîtes dimension.\\n\\n■ Connexion de camarade à une boîte dimension\\nVous devez connecter vos camarades aux dispositifs\\ninstallés dans les boîtes dimension pour obtenir diverses récompenses.\\n* Vos camarades ne peuvent être connectés qu'à un dispositif par boîte dimension.\\n\\n■ À propos de la surcharge\\nLes effets de debuff suivants s'appliquent en fonction de la valeur de la « surcharge » qui augmente chaque fois qu'un combat est mené dans la boîte dimension.\\n\\n▶ Surcharge de l'attaquant (A.OVR)\\n- Surcharge de 15 % ou plus : l'attaque de base, la défense de base et les PV de base diminuent de 10 %\\n- Surcharge de 30 % ou plus : l'attaque de base, la défense de base et les PV de base diminuent de 30 %\\n- Surcharge de 45 % ou plus : l'attaque de base, la défense de base et les PV de base diminuent de 70 %\\n- Surcharge de 60 % ou plus : l'attaque de base, la défense de base et les PV de base diminuent de 80 %\\n- Surcharge de 90 % ou plus : l'attaque de base, la défense de base et les PV de base diminuent de 99 %\\n\\n▶ Surcharge du défenseur (D.OVR)\\n- Surcharge de 15 % ou plus : l'attaque de base et la défense de base diminuent de 15 %\\n- Surcharge de 30 % ou plus : l'attaque de base et la défense de base diminuent de 35 %\\n- Surcharge de 45 % ou plus : l'attaque de base et la défense de base diminuent de 75 %\\n- Surcharge de 60 % ou plus : l'attaque de base et la défense de base diminuent de 85 %\\n- Surcharge de 90 % ou plus : l'attaque de base et la défense de base diminuent de 99 %\\n\\n* La valeur de surcharge diminue au fil du temps.\\n\\nNous espérons que vous continuerez de soutenir DIGIMON UP.\"},{\"_languageType\":4,\"_title\":\"[공지] 이차원 박스에 대한 추가 안내\",\"_message\":\"이차원 박스 콘텐츠의 자세한 내용을 공지에서 안내 드립니다.\\n\\n■ 이차원 박스에서의 버디 접속\\n이차원 박스에서 다양한 보상을 획득하려면 이차원 박스에 배치된 기기에 보유한 버디를 접속시켜야 합니다.\\n\u203B 이차원 박스 하나당 한 대의 기기에만 보유한 버디를 접속시킬 수 있습니다.\\n\\n■ 오버로드\\n이차원 박스에서 전투할 때마다 상승하는 \u2018오버로드\u2019 수치별 디버프는 다음과 같습니다.\\n\\n▶ 공격 측의 오버로드(A.OVR)\\n・오버로드 15% 이상: 기본 공격력, 기본 방어력, 기본 체력 10% 감소\\n・오버로드 30% 이상: 기본 공격력, 기본 방어력, 기본 체력 30% 감소\\n・오버로드 45% 이상: 기본 공격력, 기본 방어력, 기본 체력 70% 감소\\n・오버로드 60% 이상: 기본 공격력, 기본 방어력, 기본 체력 80% 감소\\n・오버로드 90% 이상: 기본 공격력, 기본 방어력, 기본 체력 99% 감소\\n\\n▶ 수비 측의 오버로드(D.OVR)\\n・오버로드 15% 이상: 기본 공격력, 기본 방어력 15% 감소\\n・오버로드 30% 이상: 기본 공격력, 기본 방어력 35% 감소\\n・오버로드 45% 이상: 기본 공격력, 기본 방어력 75% 감소\\n・오버로드 60% 이상: 기본 공격력, 기본 방어력 85% 감소\\n・오버로드 90% 이상: 기본 공격력, 기본 방어력 99% 감소\\n\\n\u203B '오버로드' 수치는 시간 경과에 따라 감소합니다.\\n\\n앞으로도 '디지몬 UP'에 많은 성원 부탁드립니다.\"},{\"_languageType\":8,\"_title\":\"[Anúncio] Explicação da Caixa de Dimensão Paralela\",\"_message\":\"Obrigado por jogar nosso aplicativo.\\nAqui é a Equipe de Administração do DIGIMON UP.\\n\\nAbaixo, apresentamos explicações detalhadas sobre os conteúdos da Caixa de Dimensão Paralela.\\n\\n■ Ligar Amigos à Caixa de Dimensão Paralela\\nPara obter várias recompensas na Caixa de Dimensão Paralela,\\nvocê precisa conectar um Amigo a ela usando o dispositivo integrado na Caixa.\\n* Só é possível conectar 1 Amigo por dispositivo.\\n\\n■ Sobre a Sobrecarga\\nAs seguintes penalidades acontecem conforme você batalha na Caixa de Dimensão Paralela e seu nível de Sobrecarga aumenta.\\n\\n▶ Sobrecarga do Atacante (A.OVR)\\n・Sobrecarga em 15% ou mais: Ataque base, Defesa base e Vida base reduzidos em 10%.\\n・Sobrecarga em 30% ou mais: Ataque base, Defesa base e Vida base reduzidos em 30%.\\n・Sobrecarga em 45% ou mais: Ataque base, Defesa base e Vida base reduzidos em 70%.\\n・Sobrecarga em 60% ou mais: Ataque base, Defesa base e Vida base reduzidos em 80%.\\n・Sobrecarga em 90% ou mais: Ataque base, Defesa base e Vida base reduzidos em 99%.\\n\\n▶ Sobrecarga do Defensor (D.OVR)\\n・Sobrecarga em 15% ou mais: Ataque base e Defesa base reduzidos em 15%.\\n・Sobrecarga em 30% ou mais: Ataque base e Defesa base reduzidos em 35%.\\n・Sobrecarga em 45% ou mais: Ataque base e Defesa base reduzidos em 75%.\\n・Sobrecarga em 60% ou mais: Ataque base e Defesa base reduzidos em 85%.\\n・Sobrecarga em 90% ou mais: Ataque base e Defesa base reduzidos em 99%.\\n\\n* O valor da Sobrecarga diminui com o tempo.\\n\\nEsperamos que você continue se divertindo com DIGIMON UP.\"}]}},{\"_noticeId\":\"2132118a-9134-479e-bc55-c7fe9fe2efa8\",\"_type\":3,\"_contents\":{\"_list\":[{\"_languageType\":4,\"_title\":\"[공지] 리셋 기준 시간에 대한 안내\",\"_message\":\"리셋 기준 시간에 대해 안내 드립니다.\\n・일일 리셋 - 매일 15:00\\n・주간 리셋 - 매주 수요일 15:00\\n\\n앞으로도 \u2018디지몬 UP\u2019에 많은 성원 부탁드립니다.\"},{\"_languageType\":1,\"_title\":\"【お知らせ】リセット基準時刻について\",\"_message\":\" リセット基準時刻についてご案内いたします。\\n ・デイリーリセット：毎日15:00\\n ・ウィークリーリセット：毎週水曜日15:00\\n \\n 今後とも「デジモンUP」をよろしくお願いいたします。\"},{\"_languageType\":6,\"_title\":\"[Mitteilung] Reset-Zeiten\",\"_message\":\"Vielen Dank, dass du unser Spiel spielst.\\nHier ist das \u201EDIGIMON UP\u201C-Team.\\n\\nWir möchten dich über die Reset-Zeiten informieren.\\n・Täglicher Reset: täglich um 15:00 Uhr (UTC+9)\\n・Wöchentlicher Reset: jeden Mittwoch um 15:00 Uhr (UTC+9)\\n\\nWir danken dir für deine weitere Unterstützung von \u201EDIGIMON UP\u201C.\"},{\"_languageType\":8,\"_title\":\"[Anúncio] Sobre o horário de reinício\",\"_message\":\"Obrigado por jogar nosso aplicativo.\\nAqui é a Equipe de Administração do DIGIMON UP.\\n\\nAbaixo, apresentamos informação sobre o horário de reinício.\\n・ Reinício diário: às 15:00 (UTC+9)\\n・ Reinício semanal: todas as quartas-feiras às 15:00 (UTC+9)\\n\\nEsperamos que você continue se divertindo com DIGIMON UP.\"},{\"_languageType\":3,\"_title\":\"【通知】關於系統重置時間\",\"_message\":\"感謝您一直以來的支持與喜愛。\\n這裡是《數碼寶貝 UP》營運團隊。\\n\\n在此針對系統重置時間進行說明。\\n\u2027每日重置：每日15:00(UTC+9)\\n\u2027每週重置：每週三15:00(UTC+9)\\n\\n今後還請繼續支持《數碼寶貝 UP》。\"},{\"_languageType\":7,\"_title\":\"[Aviso] Sobre las horas de reinicio\",\"_message\":\"Gracias por jugar DIGIMON UP.\\nSomos el equipo de administración.\\n\\nA continuación, les informamos sobre los horarios de reinicio.\\n・Reinicio diario: todos los días a las 15:00 (UTC+9)\\n・Reinicio semanal: todos los miércoles a las 15:00 (UTC+9) \\n\\nEsperamos que sigas disfrutando de DIGIMON UP.\"},{\"_languageType\":2,\"_title\":\"【通知】关于系统重置时间\",\"_message\":\"感谢您一直以来的支持与喜爱。\\n这里是《数码宝贝 UP》运营团队。\\n\\n现就系统重置时间进行说明。\\n·每日重置：每日15:00(UTC+9)\\n·每周重置：每周三15:00(UTC+9)\\n\\n今后还请继续支持《数码宝贝 UP》。\"},{\"_languageType\":0,\"_title\":\"[Notice] About Reset Times\",\"_message\":\"Thank you for playing DIGIMON UP!\\nHere's an update from the DIGIMON UP Team.\\n\\nPlease note that reset times are scheduled as follows:\\n\u2022 Daily Reset: Every day at 15:00 (UTC +9)\\n\u2022 Weekly Reset: Every Wednesday at 15:00 (UTC +9)\\n\\nWe hope you continue to enjoy DIGIMON UP!\"},{\"_languageType\":5,\"_title\":\"[Annonce] Heures de réinitialisation\",\"_message\":\"Nous vous remercions de jouer à notre jeu.\\nNous sommes l'équipe de gestion de DIGIMON UP.\\n\\nVoici les heures de réinitialisation du jeu.\\n- Réinitialisation quotidienne : tous les jours à 15 h 00 (UTC+9)\\n- Réinitialisation hebdomadaire : tous les mercredis à 15 h 00 (UTC+9)\\n\\nNous espérons que vous continuerez de soutenir DIGIMON UP.\"}]}}]}}","charset":"utf-8"}}},{"status":"COMPLETE","method":"POST","protocolVersion":"HTTP/1.1","scheme":"https","host":"dm-content.dgup.channel.or.jp","actualPort":443,"path":"/api/dimensional-box/info","query":null,"tunnel":false,"keptAlive":true,"webSocket":false,"remoteAddress":"dm-content.dgup.channel.or.jp/99.83.175.186","clientAddress":"198.18.72.253/198.18.72.253","times":{"start":"2026-07-16T20:48:18.235+08:00","requestBegin":"2026-07-16T20:48:18.239+08:00","requestComplete":"2026-07-16T20:48:18.542+08:00","responseBegin":"2026-07-16T20:48:18.645+08:00","end":"2026-07-16T20:48:18.666+08:00"},"durations":{},"totalSize":"4844","s